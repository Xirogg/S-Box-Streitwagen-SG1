@code
{
	// ====================================================================
	//  EDITOR-SLOTS — im Inspector die PNGs aus
	//  "Assets/UI/2D Lobby UI/Main Menu UI" hineinziehen.
	// ====================================================================

	[Group( "Lobby UI – Rahmen" )]
	[Property] public Texture Title { get; set; }                 // GameTitle_MainMenu (CHONK)
	[Group( "Lobby UI – Rahmen" )]
	[Property] public Texture MapFrame { get; set; }             // UI_Map_MainMenu
	[Group( "Lobby UI – Rahmen" )]
	[Property] public Texture AbilityPanel { get; set; }         // UI_Fähigkeit&Waagen_MainMenu
	[Group( "Lobby UI – Rahmen" )]
	[Property] public Texture CharacterSlot { get; set; }        // UI_Character_MainMenu
	[Group( "Lobby UI – Rahmen" )]
	[Property] public Texture PlayerAvatar { get; set; }         // Avatar-Bild im Charakter-Slot

	[Group( "Lobby UI – Buttons" )]
	[Property] public Texture MenuButton { get; set; }           // Button_MainMenu (orange)
	[Group( "Lobby UI – Buttons" )]
	[Property] public Texture ReadyButton { get; set; }          // ReadyButton_MainMenu (grün)
	[Group( "Lobby UI – Buttons" )]
	[Property] public Texture NotReadyButton { get; set; }       // NotReadyButton_MainMenu (rot)

	[Group( "Lobby UI – Status Icons" )]
	[Property] public Texture ReadyIcon { get; set; }            // ReadyIcon_MainMenu (grüner Haken)
	[Group( "Lobby UI – Status Icons" )]
	[Property] public Texture NotReadyIcon { get; set; }         // NotReadyIcon_MainMenu (rotes X)
	[Group( "Lobby UI – Status Icons" )]
	[Property] public Texture DisconnectedIcon { get; set; }     // DisconnectedIcon_MainMenu (grau)

	[Group( "Lobby UI – Götter (später)" )]
	[Property] public Texture Dionysos { get; set; }
	[Group( "Lobby UI – Götter (später)" )]
	[Property] public Texture Laverna { get; set; }
	[Group( "Lobby UI – Götter (später)" )]
	[Property] public Texture Maat { get; set; }
	[Group( "Lobby UI – Götter (später)" )]
	[Property] public Texture Taranis { get; set; }

	[Group( "Lobby UI – Layout" )]
	[Property, Range( 1, 8 )] public int SlotCount { get; set; } = 8;

	// ====================================================================
	//  Daten
	// ====================================================================

	LobbyPlayer LocalPlayer => Scene.GetAllComponents<LobbyPlayer>()
		.FirstOrDefault( p => p.Network.IsOwner );

	IEnumerable<LobbyPlayer> AllPlayers => Scene.GetAllComponents<LobbyPlayer>();

	// Stabile Reihenfolge, damit Slots nicht bei jedem Frame springen.
	List<LobbyPlayer> OrderedPlayers => AllPlayers
		.OrderBy( p => DisplayNameFor( p ) )
		.ThenBy( p => p.GameObject.Id )
		.ToList();

	// Anzeigename eines Spielers: Custom-Nickname (falls gesetzt), sonst Steam-Name –
	// aufgelöst über den host-gespiegelten PlayerNameManager (auf jedem Peer verfügbar).
	string DisplayNameFor( LobbyPlayer p )
		=> p is null ? "" : PlayerNameManager.GetDisplayName( p.Network.Owner );

	bool LocalIsReady => LocalPlayer?.IsReady ?? false;
	bool CountdownActive => LobbyManager.Instance?.CountdownActive ?? false;
	TrackSelection CurrentTrack => LobbyManager.Instance?.SelectedTrack ?? TrackSelection.Rom;

	int ReadyCount => AllPlayers.Count( p => p.IsReady );
	int TotalCount => AllPlayers.Count();

	// Eigener Publicity-Stand (host-gespiegelt pro Peer).
	int LocalCurrency => PublicityCurrencyManager.LocalCurrency;

	string CountdownDisplay => MathF.Ceiling( LobbyManager.Instance?.CountdownTimeLeft ?? 0f )
		.ToString( "0" );

	string TrackDisplayName => CurrentTrack switch
	{
		TrackSelection.Rom => "Rom",
		TrackSelection.Aegypten => "Ägypten",
		TrackSelection.Akropolis => "Akropolis",
		_ => "???"
	};

	// True, solange das Bestenlisten-Popup offen ist. Rein lokale UI (nicht synchronisiert):
	// jeder Spieler öffnet/schließt es für sich.
	bool RecordsOpen;

	// Namens-Popup: offen-Zustand + aktueller Textfeld-Inhalt. NameInput bewusst NICHT im
	// BuildHash, sonst würde jeder Tastendruck das Panel neu bauen.
	bool NamePopupOpen;
	string NameInput = "";

	int MaxNameLength => PlayerNameManager.MaxNameLength;

	// Steam-Name des lokalen Spielers – Platzhalter im Textfeld, wenn (noch) kein Custom-Name.
	string LocalSteamName => Connection.Local?.DisplayName ?? "";

	// Die Lobby wählt Strecken über TrackSelection (Rom/Aegypten/Akropolis), die Rekorde
	// liegen aber unter RaceTrack (Rom/Egypt/Greece) – hier die Zuordnung.
	RaceTrack CurrentRaceTrack => CurrentTrack switch
	{
		TrackSelection.Rom => RaceTrack.Rom,
		TrackSelection.Aegypten => RaceTrack.Egypt,
		TrackSelection.Akropolis => RaceTrack.Greece,
		_ => RaceTrack.Rom
	};

	// Top 5 der aktuell in der Lobby gewählten Strecke (schnellste zuerst). Kommt aus dem
	// host-gespiegelten Store des RaceRecordManager – auf jedem Peer verfügbar.
	IReadOnlyList<RaceRecordEntry> CurrentRecords => RaceRecordManager.GetRecords( CurrentRaceTrack );

	// Status-Icon je Slot: leer -> getrennt, sonst bereit/nicht bereit.
	Texture StatusIcon( LobbyPlayer p )
		=> p is null ? DisconnectedIcon : (p.IsReady ? ReadyIcon : NotReadyIcon);

	// ====================================================================
	//  Texturen per Code setzen (siehe Datei-Kommentar oben)
	// ====================================================================

	// Wird nach jedem Aufbau des Panel-Baums aufgerufen -> Bilder (neu) setzen.
	// Re-Apply nötig, weil ein Rebuild Panels neu erzeugen kann.
	protected override void OnTreeBuilt() => ApplyTextures();

	void ApplyTextures()
	{
		var root = Panel;
		if ( root is null ) return;

		SetBgAll( root, "menu-btn", MenuButton );
		SetBgAll( root, "title", Title );
		SetBgAll( root, "ability-panel", AbilityPanel );
		SetBgAll( root, "map-frame", MapFrame );

		// Zustandsabhängig:
		SetBgAll( root, "ready-bar", LocalIsReady ? ReadyButton : NotReadyButton );
		SetBgAll( root, "map-preview", LobbyManager.Instance?.GetTrackTexture( CurrentTrack ) );

		// Spieler-Slots in DOM-Reihenfolge den Spielern zuordnen (gleiche
		// Reihenfolge wie die for-Schleife im Markup -> OrderedPlayers).
		var players = OrderedPlayers;
		var slots = FindByClass( root, "slot" ).ToList();
		for ( int i = 0; i < slots.Count; i++ )
		{
			SetBg( slots[i], CharacterSlot );
			var p = i < players.Count ? players[i] : null;

			// Avatar-Panel existiert nur in belegten Slots (siehe Markup) -> für leere
			// Slots ist es null und SetBg macht nichts.
			var avatar = FindByClass( slots[i], "slot-avatar" ).FirstOrDefault();
			SetBg( avatar, PlayerAvatar );

			var status = FindByClass( slots[i], "slot-status" ).FirstOrDefault();
			SetBg( status, StatusIcon( p ) );
		}
	}

	static void SetBgAll( Panel root, string cls, Texture tex )
	{
		if ( tex is null ) return;
		foreach ( var pnl in FindByClass( root, cls ) )
			pnl.Style.SetBackgroundImage( tex );
	}

	static void SetBg( Panel pnl, Texture tex )
	{
		if ( pnl is null || tex is null ) return;
		pnl.Style.SetBackgroundImage( tex );
	}

	// Alle Panels unter root (inkl. root) mit der CSS-Klasse cls.
	static IEnumerable<Panel> FindByClass( Panel root, string cls )
	{
		if ( root is null ) yield break;
		if ( root.HasClass( cls ) ) yield return root;
		foreach ( var child in root.Children )
			foreach ( var found in FindByClass( child, cls ) )
				yield return found;
	}

	// Einmaliger Diagnose-Log: warnt, welche Editor-Slots noch leer/ungültig sind.
	protected override void OnTreeFirstBuilt()
	{
		var all = new (string Name, Texture Tex)[]
		{
			(nameof( Title ), Title), (nameof( MapFrame ), MapFrame),
			(nameof( AbilityPanel ), AbilityPanel), (nameof( CharacterSlot ), CharacterSlot),
			(nameof( PlayerAvatar ), PlayerAvatar),
			(nameof( MenuButton ), MenuButton), (nameof( ReadyButton ), ReadyButton), (nameof( NotReadyButton ), NotReadyButton),
			(nameof( ReadyIcon ), ReadyIcon), (nameof( NotReadyIcon ), NotReadyIcon), (nameof( DisconnectedIcon ), DisconnectedIcon),
		};
		foreach ( var (name, tex) in all )
			if ( tex is null || !tex.IsValid )
				Log.Warning( $"[LobbyGUI] Textur nicht zugewiesen/ungültig: {name}" );
	}

	// ====================================================================
	//  Aktionen
	// ====================================================================

	void ToggleReady()
	{
		LobbyUISFX.Instance?.PlayButtonSound();   // lokaler Klick-Sound (nur dieser Spieler)
		var player = LocalPlayer;
		if ( player is null ) return;
		player.SetReady( !player.IsReady );
	}

	void CycleTrack()
	{
		LobbyUISFX.Instance?.PlayButtonSound();   // lokaler Klick-Sound (nur dieser Spieler)
		LocalPlayer?.RequestCycleTrack();
	}

	// Rechtsklick auf die Map -> Bestenliste der aktuellen Strecke öffnen. Beim Öffnen die
	// Rekorde frisch nachladen (Host liest die Datei neu & verteilt sie; Client bittet den
	// Host darum) – so ist die Liste garantiert aktuell.
	void OpenRecords()
	{
		LobbyUISFX.Instance?.PlayButtonSound();   // lokaler Klick-Sound (nur dieser Spieler)
		RaceRecordManager.RequestReload();
		RecordsOpen = true;
	}

	// Rechtsklick irgendwo (auf das Vollbild-Overlay) -> schließen.
	void CloseRecords()
	{
		RecordsOpen = false;
	}

	// Linksklick auf einen Spieler-Slot: nur der EIGENE Slot öffnet das Namens-Popup.
	void OnSlotClicked( LobbyPlayer p )
	{
		if ( p is null || !p.Network.IsOwner ) return;

		LobbyUISFX.Instance?.PlayButtonSound();
		NameInput = PlayerNameManager.LocalCustomNameOrEmpty; // aktuellen Custom-Namen vorbelegen
		NamePopupOpen = true;                                 // Hotkey-Sperre setzt OnUpdate (siehe unten)
	}

	// "Fertig": Namen übernehmen (leer = zurück zum Steam-Namen) und Popup schließen.
	void ConfirmName()
	{
		LobbyUISFX.Instance?.PlayButtonSound();
		PlayerNameManager.SetLocalName( NameInput );
		NamePopupOpen = false;
	}

	// Linksklick "Zurücksetzen" -> alle Rekorde der aktuell gewählten Strecke löschen.
	// Popup bleibt offen und zeigt sofort die leere Liste (host) bzw. nach RPC-Antwort (client).
	void ResetCurrentTrack()
	{
		LobbyUISFX.Instance?.PlayButtonSound();
		RaceRecordManager.RequestClearTrack( CurrentRaceTrack );
	}

	// Linksklick "Alles Zurücksetzen" -> alle Rekorde ALLER Strecken löschen.
	void ResetAllTracks()
	{
		LobbyUISFX.Instance?.PlayButtonSound();
		RaceRecordManager.RequestClearAll();
	}

	// TEST-Button: Ein Linksklick irgendwo auf dem Vollbild-Button wechselt auf den
	// Altar-Screen. Nutzt die schon vorhandene, getestete Umschalt-Logik im
	// LobbyManager (LobbyScreen-Component aus, AltarScreen-Component an).
	void TestSwitchToAltar()
	{
		LobbyUISFX.Instance?.PlayButtonSound();   // lokaler Klick-Sound (nur dieser Spieler)

		// Diagnose: zeigt im Console-Log, dass der Klick wirklich ankommt. Wenn diese
		// Zeile beim Klicken NICHT erscheint, erreicht der Klick das Panel nicht
		// (Pointer-Events/Überdeckung). Erscheint sie, aber kein Screenwechsel,
		// liegt es an LobbyManager.Instance / den Screen-Zuweisungen.
		Log.Info( $"[LobbyGUI] TEST-Button geklickt. LobbyManager.Instance = {(LobbyManager.Instance is null ? "NULL" : "OK")}" );
		LobbyManager.Instance?.ShowAltar();
	}

	void QuitGame()
	{
		LobbyUISFX.Instance?.PlayButtonSound();   // lokaler Klick-Sound (nur dieser Spieler)
		Log.Info( "Quitting game..." );
		Game.Close();
	}

	protected override void OnUpdate()
	{
		// Maus im Menü immer sichtbar, sonst sind die Buttons nicht anklickbar.
		// Jeden Frame setzen, damit andere Systeme den Cursor nicht wegnehmen.
		Mouse.Visibility = MouseVisibility.Visible;

		// Hotkey-Sperre spiegelt IMMER den echten Popup-Zustand (selbstkorrigierend, damit
		// die Sperre nicht z. B. nach einem Szenenwechsel hängen bleibt). LobbyPlayer liest
		// dieses Flag, um Space/Tab beim Tippen zu ignorieren.
		PlayerNameManager.LocalNameInputActive = NamePopupOpen;

		// Nicht beenden, während der Spieler seinen Namen tippt (Quit hängt auf Entf).
		if ( !NamePopupOpen && Input.Pressed( "Quit" ) )
			Game.Close();
	}

	protected override int BuildHash()
	{
		var hash = new HashCode();
		hash.Add( CountdownActive );
		hash.Add( LobbyManager.Instance?.CountdownTimeLeft );
		hash.Add( CurrentTrack );
		hash.Add( TotalCount );
		hash.Add( LocalIsReady );
		hash.Add( LocalCurrency );
		hash.Add( SlotCount );
		foreach ( var p in OrderedPlayers )
		{
			hash.Add( p.IsReady );
			hash.Add( DisplayNameFor( p ) ); // Custom-Name/Steam-Name -> UI aktualisiert sich bei Änderung
		}

		// Popup-Zustand + Inhalt: rebuildet die UI, wenn es geöffnet/geschlossen wird oder
		// wenn (nach einem Reload) neue Rekorde für die gezeigte Strecke reinkommen.
		hash.Add( RecordsOpen );
		if ( RecordsOpen )
		{
			hash.Add( CurrentRaceTrack );
			foreach ( var e in CurrentRecords )
			{
				hash.Add( e.PlayerName );
				hash.Add( e.TimeSeconds );
				hash.Add( e.Date );
			}
		}

		// Namens-Popup auf/zu. NameInput bewusst NICHT im Hash (sonst Rebuild pro Tastendruck).
		hash.Add( NamePopupOpen );

		return hash.ToHashCode();
	}
}
