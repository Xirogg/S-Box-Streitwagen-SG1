@using Sandbox;
@using Sandbox.UI;
@using System.Linq;
@inherits PanelComponent
@using System;

<root>
	<div class="scroll-bg-wrap">
		<div class="scroll-bg-track">
			<div class="scroll-bg-tile"></div>
			<div class="scroll-bg-tile"></div>
		</div>
	</div>

	<div class="track-section">
		<div class="track-label">Ausgewählte Strecke:</div>
		<div class="track-name @TrackClass">
			<div class="track-preview" style="background-image: url(@TrackImagePath);"></div>
			<div class="track-title">@TrackDisplayName</div>
			<div class="track-hotkey">Tab</div>
		</div>
	</div>

	@if ( CountdownActive )
	{
		<div class="center-area">
			<div class="countdown">@CountdownDisplay</div>
		</div>
	}
	else
	{
		<div class="center-area">
			<div class="ready-button @ReadyClass" onclick="@ToggleReady">
				<div class="ready-title">@( LocalIsReady ? "Bereit!" : "Bereit?" )</div>
				<div class="ready-info">Space — @ReadyCount / @TotalCount</div>
			</div>
		</div>
	}

	<div class="quit-button" onclick="@QuitGame">
		<div class="quit-title">Quit Game</div>
		<div class="quit-hotkey">DEL</div>
	</div>

	<div class="currency-label">Currency: @LocalCurrency</div>
</root>

<style>
	root {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
	}

	/* Seamless scrolling background. Two identical tiles sit side-by-side inside
	   a 200%-wide track; the track translateX-animates from 0 to -50% (= exactly
	   one tile width) on infinite linear loop, so when the second tile snaps
	   back to start it visually equals the first, hiding the seam. */
	.scroll-bg-wrap {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		overflow: hidden;
		background-color: rgba(15, 20, 45, 1);
	}

	.scroll-bg-track {
		position: absolute;
		left: 0;
		top: 0;
		width: 200%;
		height: 100%;
		flex-direction: row;
		animation: scroll-bg-x 40s linear infinite;
	}

	.scroll-bg-tile {
		width: 50%;
		height: 100%;
		background-image: url( "/ui/ingame gui/lobby/main_scroll_bg.jpg" );
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}

	@@keyframes scroll-bg-x {
		0%   { transform: translateX( 0% ); }
		100% { transform: translateX( -50% ); }
	}

	.track-section {
		position: absolute;
		top: 48px;
		right: 48px;
		flex-direction: column;
		align-items: flex-end;
		gap: 16px;
	}

	.track-label {
		font-size: 40px;
		font-family: Arial;
		color: rgba(255, 255, 255, 0.7);
	}

	.track-name {
		padding: 20px 32px;
		font-family: Arial;
		color: white;
		border-radius: 16px;
		text-align: center;
		flex-direction: column;
		align-items: center;
		gap: 12px;
	}

	.track-preview {
		width: 480px;
		height: 270px;
		border-radius: 10px;
		background-size: cover;
		background-position: center;
		background-color: rgba(0, 0, 0, 0.4);
		border: 3px solid rgba(255, 255, 255, 0.2);
	}

	.track-title {
		font-size: 56px;
		font-weight: bold;
	}

	.track-hotkey {
		font-size: 28px;
		color: rgba(255, 255, 255, 0.5);
	}

	.track-rom {
		background-color: rgba(180, 60, 60, 0.85);
		border: 4px solid rgba(220, 100, 100, 0.6);
	}

	.track-aegypten {
		background-color: rgba(50, 150, 60, 0.85);
		border: 4px solid rgba(90, 200, 100, 0.6);
	}

	.track-akropolis {
		background-color: rgba(50, 80, 180, 0.85);
		border: 4px solid rgba(90, 120, 220, 0.6);
	}

	.center-area {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		justify-content: center;
		align-items: center;
	}

	.ready-button {
		padding: 48px 160px;
		font-family: Arial;
		color: white;
		background-color: rgba(80, 80, 80, 0.9);
		border-radius: 24px;
		cursor: pointer;
		text-align: center;
		transition: background-color 0.2s ease;
		border: 6px solid rgba(255, 255, 255, 0.3);
		flex-direction: column;
		align-items: center;
		gap: 12px;
	}

	.ready-button:hover {
		background-color: rgba(120, 120, 120, 0.9);
	}

	.ready-button.is-ready {
		background-color: rgba(40, 160, 40, 0.9);
		border-color: rgba(80, 220, 80, 0.6);
	}

	.ready-button.is-ready:hover {
		background-color: rgba(30, 130, 30, 0.9);
	}

	.ready-title {
		font-size: 84px;
		font-weight: bold;
	}

	.ready-info {
		font-size: 36px;
		color: rgba(255, 255, 255, 0.6);
	}

	.countdown {
		font-size: 256px;
		font-family: Arial;
		font-weight: bold;
		color: white;
		text-shadow: 0px 4px 8px rgba(0, 0, 0, 0.8);
	}

	.quit-button {
		position: absolute;
		bottom: 48px;
		right: 48px;
		padding: 20px 48px;
		background-color: rgba(50, 50, 50, 0.9);
		border: 4px solid rgba(255, 255, 255, 0.2);
		border-radius: 16px;
		cursor: pointer;
		flex-direction: row;
		align-items: center;
		gap: 24px;
		transition: background-color 0.2s ease;
	}

	.quit-button:hover {
		background-color: rgba(80, 80, 80, 0.9);
	}

	.quit-title {
		font-size: 40px;
		font-family: Arial;
		color: white;
	}

	.quit-hotkey {
		font-size: 28px;
		font-family: Arial;
		color: rgba(255, 255, 255, 0.5);
	}

	.currency-label {
		position: absolute;
		bottom: 48px;
		left: 48px;
		padding: 16px 32px;
		font-size: 40px;
		font-family: Arial;
		color: rgba(255, 220, 80, 1);
		background-color: rgba(0, 0, 0, 0.55);
		border: 3px solid rgba(255, 220, 80, 0.6);
		border-radius: 12px;
		text-shadow: 0px 2px 4px black;
	}
</style>

@code
{
	LobbyPlayer LocalPlayer => Scene.GetAllComponents<LobbyPlayer>()
		.FirstOrDefault( p => p.Network.IsOwner );

	IEnumerable<LobbyPlayer> AllPlayers => Scene.GetAllComponents<LobbyPlayer>();

	bool LocalIsReady => LocalPlayer?.IsReady ?? false;
	bool CountdownActive => LobbyManager.Instance?.CountdownActive ?? false;
	TrackSelection CurrentTrack => LobbyManager.Instance?.SelectedTrack ?? TrackSelection.Rom;

	int ReadyCount => AllPlayers.Count( p => p.IsReady );
	int TotalCount => AllPlayers.Count();

	// Local player's PG. The host pushes per-peer mirrors via RpcSetCurrency,
	// so each peer reads its own total without trusting other clients.
	int LocalCurrency => PublicityCurrencyManager.LocalCurrency;

	string CountdownDisplay => MathF.Ceiling( LobbyManager.Instance?.CountdownTimeLeft ?? 0f )
		.ToString( "0" );
	string ReadyClass => LocalIsReady ? "is-ready" : "";

	// Routed through LobbyManager so the path comes from the strongly-typed
	// Texture properties the asset pipeline can see — that's what guarantees the
	// PNGs are bundled into the package joining clients download. The previous
	// hardcoded "/ui/tracks/..." strings were invisible to the reference scanner,
	// so the files weren't shipped and only the editor host saw the previews.
	string TrackImagePath => LobbyManager.Instance?.GetTrackImagePath( CurrentTrack ) ?? "";

	string TrackDisplayName => CurrentTrack switch
	{
		TrackSelection.Rom => "Rom",
		TrackSelection.Aegypten => "Ägypten",
		TrackSelection.Akropolis => "Akropolis",
		_ => "???"
	};

	string TrackClass => CurrentTrack switch
	{
		TrackSelection.Rom => "track-rom",
		TrackSelection.Aegypten => "track-aegypten",
		TrackSelection.Akropolis => "track-akropolis",
		_ => ""
	};

	void ToggleReady()
	{
		var player = LocalPlayer;
		if ( player is null ) return;
		player.SetReady( !player.IsReady );
	}

	void QuitGame()
	{
		Log.Info("Quitting game..." );
		Game.Close();
	}

	protected override void OnUpdate()
	{
		if ( Input.Pressed( "Quit" ) )
			Game.Close();
	}

	protected override int BuildHash()
	{
		var hash = new HashCode();
		hash.Add( CountdownActive );
		hash.Add( LobbyManager.Instance?.CountdownTimeLeft );
		hash.Add( CurrentTrack );
		hash.Add( TotalCount );
		hash.Add( LocalCurrency );
		foreach ( var p in AllPlayers )
		{
			hash.Add( p.IsReady );
		}
		return hash.ToHashCode();
	}
}
