	}

	/* "Alles Zurücksetzen" – rötlich, weil deutlich destruktiver. */
	.records-btn.danger {
		background-color: rgba(205, 95, 70, 0.95);
		color: white;
		border-color: rgba(150, 50, 30, 0.85);
	}

	.records-btn.danger:hover {
		background-color: rgba(225, 115, 85, 1);
	}

	/* ----------------------------- Namens-Popup ----------------------------- */
	.name-overlay {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		z-index: 350;
		pointer-events: all;
		align-items: center;
