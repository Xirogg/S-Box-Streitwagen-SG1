@using Sandbox;
@using Sandbox.UI;
@using System;
@using System.Linq;
@using System.Collections.Generic;
@using LapSystem;
@inherits PanelComponent
@namespace Sandbox.Scripts.GUI.Lobby

@*
	LOBBY / MAIN MENU UI  (Streitwagen-Wallah)

	Aufbau nach "Aufbau_Vorlage_MainMenu.png":
	  - Links:   4 Menü-Buttons (Button_MainMenu) + CHONK-Titel (GameTitle)
	  - Mitte:   Ready-Button (NotReadyButton rot / ReadyButton grün) + Fähigkeiten-Panel (UI_Fähigkeit&Waagen)
	  - Rechts:  Map-Vorschau (UI_Map) + Spieler-Slots (UI_Character) mit Status-Icons

	ALLES über den Editor steuerbar: Jede Grafik ist eine [Property] Texture
	(Gruppen "Lobby UI – ...").

	WICHTIG: Die Bilder werden per CODE gesetzt (Style.SetBackgroundImage), NICHT
	über CSS url(@..ResourcePath). Grund: Eine Textur, die im Inspector über das
	Quellen-Menü ("Image File", "From Disk", "Color", "Gradient" …) erzeugt wird,
	hat KEINEN gültigen ResourcePath, also kann url() sie nicht auflösen.
	SetBackgroundImage nimmt das Texture-Objekt direkt und funktioniert mit jeder
	Quelle. Größe/Position kommen weiterhin aus dem Stylesheet (background-size).
	Die Panels werden dafür per CSS-Klasse im Panel-Baum gesucht (kein @ref – das
	bindet der s&box-Razor-Generator hier nicht an Panel-Felder).

	Funktional ist aktuell NUR der Ready-Button (Multiplayer-fähig, jeder Spieler
	muss bereit sein -> Countdown -> Szenenwechsel). Der Rest ist optisches
	Gerüst und wird nach und nach verkabelt.
*@

<root>
	<!-- ======================= LINKS: Menü + Titel ======================= -->
	<div class="menu-col">
		<div class="menu-btn" onclick="@TestSwitchToAltar">
			<div class="menu-label">Opferaltar</div>
		</div>
		<div class="menu-btn disabled">
			<div class="menu-label"> Charakter</div>
		</div>
		<div class="menu-btn disabled">
			<div class="menu-label">Einstellungen</div>
		</div>
		<div class="menu-btn" onclick="@QuitGame">
			<div class="menu-label">Verlassen</div>
		</div>
	</div>

	<div class="title"></div>

	<!-- ======================= MITTE: Ready + Fähigkeiten ======================= -->
	<div class="ready-bar @( LocalIsReady ? "ready" : "notready" )" onclick="@ToggleReady">
		<div class="ready-text">@( LocalIsReady ? "Bereit!" : "Bereit?" )</div>
		<div class="ready-sub">Space · @ReadyCount / @TotalCount bereit</div>
	</div>

	<div class="ability-panel">
		<div class="ability-body">
			<div class="ability-name">@( LocalPlayer is null ? "—" : DisplayNameFor( LocalPlayer ) )</div>
			<div class="ability-hint">Fähigkeit &amp; Waagen folgen…</div>
		</div>
	</div>

	<!-- ======================= RECHTS: Map + Spieler-Slots ======================= -->
	<div class="map-frame">
		<div class="map-preview"></div>
		<div class="map-caption">@TrackDisplayName</div>
	</div>

	<div class="slot-grid">
		@{
			var players = OrderedPlayers;
		}
		@for ( int i = 0; i < SlotCount; i++ )
		{
			var p = i < players.Count ? players[i] : null;
			bool own = p is not null && p.Network.IsOwner;
			<div class="slot @( p is null ? "empty" : "" ) @( own ? "own" : "" )">
				@if ( p is not null )
				{
					<div class="slot-avatar"></div>
				}
				<div class="slot-status"></div>
				@if ( p is not null )
				{
					<div class="slot-name">@DisplayNameFor( p )</div>
				}
				@*
					Nur der EIGENE Slot bekommt diese Klickfläche über dem Charakter-Bild
					(Linksklick öffnet das Namens-Popup). Eigenes Overlay mit pointer-events +
					fast unsichtbarem Hintergrund, weil s&box komplett durchsichtige Flächen
					nicht zuverlässig trifft (gleiches Muster wie die anderen Lobby-Buttons).
				*@
				@if ( own )
				{
					<div class="slot-rename" onclick=@(() => OnSlotClicked( p ))>
						<div class="slot-rename-hint">Name ändern</div>
					</div>
				}
			</div>
		}
	</div>

	<!-- ======================= Countdown-Overlay ======================= -->
	@if ( CountdownActive )
	{
		<div class="countdown-overlay">
			<div class="countdown">@CountdownDisplay</div>
			<div class="countdown-label">Rennen startet…</div>
		</div>
	}

	<div class="currency">PG: @LocalCurrency</div>

	<!-- ======================= Opferaltar-Button (über "Opferaltar") ======================= -->
	<!-- Klickfläche genau über dem "Opferaltar"-Menü-Button (1. Button der menu-col:
	     left 40, top 40, 380x120). Wechselt über die vorhandene Logik
	     (LobbyManager.ShowAltar) auf den AltarGUIScreen. z-index hält sie über dem
	     Button; pointer-events + ein (fast unsichtbarer) Hintergrund sichern den
	     Treffer. -->
	<div class="altar-btn" onclick="@TestSwitchToAltar"></div>

	<!-- ======================= Bereit-Button (über der Ready-Bar) ======================= -->
	<!-- Klickfläche genau über der Ready-Bar. Toggelt Bereit/Nicht-bereit über
	     dieselbe Logik wie die "Ready"-Hotkey (ToggleReady -> SetReady( !IsReady )).
	     Liegt per z-index über der Bar und fängt dort den Linksklick ab. -->
	<div class="ready-btn" onclick="@ToggleReady"></div>

	<!-- ======================= Charakter-Button (über "Charakter") ======================= -->
	<!-- Klickfläche genau über dem "Charakter"-Menü-Button (2. Button der menu-col:
	     left 40, top 190, 380x120). Zeigt nur den Hover-Effekt (Abdunkeln), löst aber
	     KEINE Aktion aus – bewusst ohne onclick. -->
	<div class="character-btn"></div>

	<!-- ======================= Strecken-Button (über der Map) ======================= -->
	<!-- Klickfläche genau über der Map-Frame (left 1060, top 40, 800x480). LINKSKLICK
	     wechselt die Strecke wie die "Change Track"-Hotkey (Tab). RECHTSKLICK öffnet die
	     Bestenliste der aktuellen Strecke (RaceRecordManager). Ohne Hover-Shader. -->
	<div class="track-btn" onclick="@CycleTrack" onrightclick="@OpenRecords"></div>

	<!-- ======================= Verlassen-Button (über "Verlassen") ======================= -->
	<!-- Klickfläche genau über dem "Verlassen"-Menü-Button (4. Button der menu-col:
	     left 40, top 40 + 3*(120+30) = 490, 380x120). Beendet das Spiel über
	     QuitGame. z-index hält sie über dem Button; pointer-events + ein (fast
	     unsichtbarer) Hintergrund sichern den Treffer. -->
	<div class="quit-btn" onclick="@QuitGame"></div>

	<!-- ======================= Bestenliste-Popup (Rechtsklick auf die Map) ======================= -->
	<!-- Vollbild-Overlay über allem (z-index 300). Es fängt den NÄCHSTEN Rechtsklick
	     irgendwo ab und schließt damit das Fenster. Weil das Overlay beim Öffnen-Klick
	     noch nicht existiert, schließt derselbe Klick es nicht sofort wieder. -->
	@if ( RecordsOpen )
	{
		<div class="records-overlay" onrightclick="@CloseRecords">
			<div class="records-window">
				<div class="records-title">Bestenzeiten — @TrackDisplayName</div>

				<div class="records-head">
					<div class="col-rank">Platz</div>
					<div class="col-name">Name</div>
					<div class="col-time">Zeit</div>
					<div class="col-date">Datum</div>
				</div>

				@{
					var recs = CurrentRecords;
				}
				@if ( recs.Count == 0 )
				{
					<div class="records-empty">Noch keine Rekorde für diese Strecke.</div>
				}
				@for ( int i = 0; i < recs.Count; i++ )
				{
					var e = recs[i];
					<div class="records-row">
						<div class="col-rank">@( i + 1 )</div>
						<div class="col-name">@e.PlayerName</div>
						<div class="col-time">@RaceRecordManager.FormatTime( e.TimeSeconds )</div>
						<div class="col-date">@RaceRecordManager.FormatRelativeDate( e.Date )</div>
					</div>
				}

				<!-- Zurücksetzen-Buttons: Linksklick. Nur der Host löscht wirklich; ein Client
				     schickt die Anfrage per RPC an den Host (siehe RaceRecordManager). -->
				<div class="records-buttons">
					<div class="records-btn" onclick="@ResetCurrentTrack">Zurücksetzen</div>
					<div class="records-btn danger" onclick="@ResetAllTracks">Alles Zurücksetzen</div>
				</div>

				<div class="records-hint">Rechtsklick zum Schließen</div>
			</div>
		</div>
	}

	<!-- ======================= Namens-Popup (Linksklick auf den eigenen Slot) ======================= -->
	<!-- Modal: das Overlay blockiert die Lobby dahinter. Geschlossen wird NUR über "Fertig"
	     (bestätigt den Namen). Das TextEntry hat MaxLength 20; SetLocalName kürzt zusätzlich. -->
	@if ( NamePopupOpen )
	{
		<div class="name-overlay">
			<div class="name-window">
				<div class="name-title">Namen anpassen</div>
				<div class="name-sub">Max. 20 Zeichen</div>

				<TextEntry class="name-input" MaxLength="@MaxNameLength" Placeholder="@LocalSteamName" Value:bind="@NameInput" />

				<div class="name-buttons">
					<div class="name-btn" onclick="@ConfirmName">Ändern</div>
				</div>
			</div>
		</div>
	}
</root>

<style>
	root {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		font-family: Arial;
		color: rgba(58, 36, 16, 1);
		/* Über dem LobbyBackgroundGUI (z-index 0), damit der scrollende Hintergrund
		   dahinter sichtbar bleibt. */
		z-index: 1;
	}

	/* ----------------------------- Links: Menü ----------------------------- */
	.menu-col {
		position: absolute;
		left: 40px;
		top: 40px;
		width: 380px;
		flex-direction: column;
		gap: 30px;
	}

	.menu-btn {
		width: 380px;
		height: 120px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: transform 0.1s ease;
	}

	.menu-btn:hover {
		transform: scale( 1.04 );
	}

	.menu-btn.disabled {
		cursor: default;
	}

	.menu-btn.disabled:hover {
		transform: scale( 1 );
	}

	.menu-label {
		font-size: 38px;
		font-weight: bold;
		color: rgba(74, 44, 12, 1);
		text-align: center;
	}

	.title {
		position: absolute;
		left: 30px;
		top: 660px;
		width: 420px;
		height: 230px;
		background-size: contain;
		background-position: center;
		background-repeat: no-repeat;
	}

	/* ----------------------------- Mitte: Ready ----------------------------- */
	.ready-bar {
		position: absolute;
		left: 540px;
		top: 50px;
		width: 470px;
		height: 150px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 6px;
		cursor: pointer;
		transition: transform 0.1s ease;
	}

	.ready-bar:hover {
		transform: scale( 1.03 );
	}

	.ready-text {
		font-size: 54px;
		font-weight: bold;
		color: white;
		text-shadow: 0px 3px 6px rgba(0, 0, 0, 0.6);
	}

	.ready-sub {
		font-size: 24px;
		color: rgba(255, 255, 255, 0.9);
		text-shadow: 0px 2px 4px rgba(0, 0, 0, 0.6);
	}

	/* ------------------------- Mitte: Fähigkeiten-Panel ------------------------- */
	.ability-panel {
		position: absolute;
		left: 540px;
		top: 230px;
		width: 470px;
		height: 770px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		align-items: center;
		justify-content: flex-end;
	}

	.ability-body {
		flex-direction: column;
		align-items: center;
		margin-bottom: 70px;
		gap: 10px;
	}

	.ability-name {
		font-size: 40px;
		font-weight: bold;
		color: rgba(74, 44, 12, 1);
	}

	.ability-hint {
		font-size: 24px;
		color: rgba(74, 44, 12, 0.7);
	}

	/* ----------------------------- Rechts: Map ----------------------------- */
	.map-frame {
		position: absolute;
		left: 1060px;
		top: 40px;
		width: 800px;
		height: 480px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
	}

	.map-preview {
		width: 86%;
		height: 72%;
		margin-top: 5%;
		background-size: 100% 100%;
		background-position: center;
		background-repeat: no-repeat;
		border-radius: 8px;
	}

	/* Nur der Streckenname (der "Tab"-Hinweis wurde entfernt, da die Map selbst
	   klickbar ist). */
	.map-caption {
		margin-top: 16px;
		font-size: 32px;
		font-weight: bold;
		color: rgba(74, 44, 12, 1);
	}

	/* ------------------------- Rechts: Spieler-Slots ------------------------- */
	.slot-grid {
		position: absolute;
		left: 1060px;
		top: 560px;
		width: 790px;
		flex-direction: row;
		flex-wrap: wrap;
		gap: 30px;
	}

	.slot {
		width: 175px;
		height: 175px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		position: relative;
		align-items: center;
		justify-content: flex-end;
	}

	.slot.empty {
		opacity: 0.4;
	}

	/* Eigener Slot: anklickbar (Linksklick öffnet das Namens-Popup). Beim Hovern glüht der
	   Rahmen golden auf (Shader-artiger Glow), damit klar ist, dass er interaktiv ist. */
	.slot.own {
		cursor: pointer;
		border-radius: 10px;
		transition: transform 0.12s ease, box-shadow 0.12s ease;
	}

	.slot.own:hover {
		transform: scale( 1.05 );
		box-shadow: 0px 0px 30px rgba(255, 210, 90, 0.95);
	}

	/* Klickfläche über dem eigenen Charakter-Bild (nur der eigene Slot, siehe Markup).
	   Fast unsichtbarer Hintergrund sichert den Treffer in s&box. */
	.slot-rename {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		z-index: 10;
		pointer-events: all;
		cursor: pointer;
		align-items: center;
		justify-content: center;
		border-radius: 10px;
		background-color: rgba(0, 0, 0, 0.04);
		transition: background-color 0.12s ease;
	}

	.slot-rename:hover {
		background-color: rgba(0, 0, 0, 0.18);
	}

	/* "Name ändern"-Hinweis: nur beim Hovern sichtbar. */
	.slot-rename-hint {
		opacity: 0;
		font-size: 22px;
		font-weight: bold;
		color: white;
		text-align: center;
		background-color: rgba(60, 40, 15, 0.85);
		border-radius: 8px;
		padding: 6px 14px;
		transition: opacity 0.12s ease;
	}

	.slot-rename:hover .slot-rename-hint {
		opacity: 1;
	}

	/* Avatar-Bild im Slot: sitzt innerhalb des Rahmens, hinter dem Status-Icon und
	   dem Namen. Nur belegte Slots erhalten dieses Panel (siehe Markup). */
	.slot-avatar {
		position: absolute;
		left: 10%;
		top: 10%;
		width: 80%;
		height: 80%;
		background-size: contain;
		background-position: center;
		background-repeat: no-repeat;
		pointer-events: none;
	}

	/* Voll-Overlay: die Icon-PNGs haben das Symbol bereits oben rechts platziert. */
	.slot-status {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		pointer-events: none;
	}

	.slot-name {
		position: absolute;
		bottom: 14px;
		max-width: 88%;
		overflow: hidden;
		font-size: 22px;
		font-weight: bold;
		color: rgba(74, 44, 12, 1);
		text-align: center;
		white-space: nowrap;
		background-color: rgba(255, 240, 210, 0.75);
		border-radius: 6px;
		padding: 2px 10px;
	}

	/* ----------------------------- Countdown ----------------------------- */
	.countdown-overlay {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		background-color: rgba(0, 0, 0, 0.55);
	}

	.countdown {
		font-size: 300px;
		font-weight: bold;
		color: white;
		text-shadow: 0px 6px 16px rgba(0, 0, 0, 0.8);
	}

	.countdown-label {
		font-size: 48px;
		color: rgba(255, 255, 255, 0.85);
	}

	/* ----------------------------- Währung ----------------------------- */
	.currency {
		position: absolute;
		left: 40px;
		bottom: 30px;
		padding: 12px 28px;
		font-size: 32px;
		font-weight: bold;
		color: rgba(90, 58, 16, 1);
		background-color: rgba(255, 225, 150, 0.85);
		border: 3px solid rgba(140, 90, 30, 0.7);
		border-radius: 12px;
	}

	/* ----------------------------- Opferaltar-Button ----------------------------- */
	/* Klickfläche genau über dem "Opferaltar"-Menü-Button (1. Button der menu-col:
	   left 40, top 40, 380x120). Öffnet den Altar-Screen. z-index hält sie über dem
	   Button; pointer-events + ein (fast unsichtbarer) Hintergrund sichern den
	   Treffer (eine komplett durchsichtige Fläche wird in s&box sonst nicht
	   zuverlässig getroffen). */
	.altar-btn {
		position: absolute;
		left: 40px;
		top: 40px;
		width: 380px;
		height: 120px;
		z-index: 100;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(0, 0, 0, 0.04);
		transition: background-color 0.1s ease;
	}

	/* Hover: leichtes Abdunkeln (halbtransparentes Schwarz über dem Opferaltar-Button). */
	.altar-btn:hover {
		background-color: rgba(0, 0, 0, 0.2);
	}

	/* ----------------------------- Charakter-Button ----------------------------- */
	/* Klickfläche genau über dem "Charakter"-Menü-Button (2. Button der menu-col:
	   left 40, top 40 + 120 Höhe + 30 gap = top 190). Behält nur den Hover-Effekt,
	   löst aber KEINE Aktion aus (kein onclick im Markup). */
	.character-btn {
		position: absolute;
		left: 40px;
		top: 190px;
		width: 380px;
		height: 120px;
		z-index: 100;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(0, 0, 0, 0.04);
		transition: background-color 0.1s ease;
	}

	/* Hover: leichtes Abdunkeln. Der Button ist ein (fast durchsichtiges) Overlay
	   ÜBER dem echten "Charakter"-Button-Graphic – ein halbtransparentes Schwarz
	   tönt den darunterliegenden Button, sodass er beim Hovern dunkler wirkt. */
	.character-btn:hover {
		background-color: rgba(0, 0, 0, 0.2);
	}

	/* ----------------------------- Strecken-Button ----------------------------- */
	/* Klickfläche genau über der Map-Frame (left 1060, top 40, 800x480). Wechselt
	   die Strecke wie die Tab-Hotkey. z-index hält sie über dem Frame; pointer-events
	   + ein (fast unsichtbarer) Hintergrund sichern den Treffer. Kein :hover-Shader,
	   damit die Map beim Überfahren nicht abdunkelt. */
	.track-btn {
		position: absolute;
		left: 1060px;
		top: 40px;
		width: 800px;
		height: 480px;
		z-index: 100;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(0, 0, 0, 0.04);
	}

	/* ----------------------------- Bereit-Button ----------------------------- */
	/* Klickfläche genau über der Ready-Bar (left 540, top 50, 470x150). Toggelt
	   Bereit/Nicht-bereit wie die Hotkey. z-index hält sie über der Bar;
	   pointer-events + ein (fast unsichtbarer) Hintergrund sichern den Treffer. */
	.ready-btn {
		position: absolute;
		left: 540px;
		top: 50px;
		width: 470px;
		height: 150px;
		z-index: 100;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(0, 0, 0, 0.04);
		transition: background-color 0.1s ease;
	}

	/* Hover: leichtes Abdunkeln (halbtransparentes Schwarz über der Ready-Bar). */
	.ready-btn:hover {
		background-color: rgba(0, 0, 0, 0.2);
	}

	/* ----------------------------- Verlassen-Button ----------------------------- */
	/* Klickfläche genau über dem "Verlassen"-Button (4. Button der menu-col:
	   left 40, top 490, 380x120). Beendet das Spiel. z-index hält sie über dem
	   Button; pointer-events + ein (fast unsichtbarer) Hintergrund sichern den
	   Treffer. */
	.quit-btn {
		position: absolute;
		left: 40px;
		top: 490px;
		width: 380px;
		height: 120px;
		z-index: 100;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(0, 0, 0, 0.04);
		transition: background-color 0.1s ease;
	}

	/* Hover: leichtes Abdunkeln (halbtransparentes Schwarz über dem Verlassen-Button). */
	.quit-btn:hover {
		background-color: rgba(0, 0, 0, 0.2);
	}

	/* ----------------------------- Bestenliste (Records-Popup) ----------------------------- */
	/* Vollbild-Overlay: fängt den nächsten Rechtsklick (irgendwo) ab und schließt damit das
	   Fenster. Liegt über allem (z-index 300 > die 100er-Klickflächen) und blockiert per
	   pointer-events die Interaktion mit dem Rest der Lobby, solange es offen ist (modal). */
	.records-overlay {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		z-index: 300;
		pointer-events: all;
		align-items: center;
		justify-content: center;
		background-color: rgba(0, 0, 0, 0.55);
	}

	.records-window {
		width: 1200px;
		flex-direction: column;
		padding: 40px 50px;
		background-color: rgba(255, 235, 195, 0.98);
		border: 5px solid rgba(140, 90, 30, 0.9);
		border-radius: 20px;
	}

	.records-title {
		font-size: 46px;
		font-weight: bold;
		color: rgba(74, 44, 12, 1);
		text-align: center;
		margin-bottom: 24px;
	}

	.records-head {
		flex-direction: row;
		padding-bottom: 12px;
		margin-bottom: 8px;
		border-bottom: 3px solid rgba(140, 90, 30, 0.6);
		font-size: 26px;
		font-weight: bold;
		color: rgba(90, 58, 16, 1);
	}

	.records-row {
		flex-direction: row;
		align-items: center;
		padding: 10px 6px;
		font-size: 30px;
		color: rgba(74, 44, 12, 1);
	}

	.records-row:hover {
		background-color: rgba(255, 210, 130, 0.5);
		border-radius: 8px;
	}

	/* Spalten: Platz + Zeit + Datum fest, Name füllt den Rest. */
	.col-rank { width: 120px; }
	.col-name { flex-grow: 1; overflow: hidden; white-space: nowrap; }
	.col-time { width: 190px; }
	.col-date { width: 250px; }

	.records-empty {
		font-size: 30px;
		color: rgba(74, 44, 12, 0.8);
		text-align: center;
		padding: 40px 0;
