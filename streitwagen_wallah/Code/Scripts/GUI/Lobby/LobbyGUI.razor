	.name-input {
		width: 100%;
		height: 74px;
		padding: 0 20px;
		font-size: 34px;
		color: rgba(74, 44, 12, 1);
		background-color: rgba(255, 250, 235, 1);
		border: 3px solid rgba(140, 90, 30, 0.7);
		border-radius: 12px;
