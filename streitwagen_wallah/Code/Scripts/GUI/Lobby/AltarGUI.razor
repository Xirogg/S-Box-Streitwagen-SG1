@using Sandbox;
@using Sandbox.UI;
@using System;
@using System.Linq;
@using System.Collections.Generic;
@inherits PanelComponent
@namespace Sandbox

@*
	OPFERALTAR-SCREEN  (Streitwagen-Wallah)

	Vier Altar-Säulen (ein Gott je Säule). KEINE Stufen mehr: jeder Gott würfelt pro
	Rennen EINE zufällige Gunst für DIESEN Spieler aus – 10% Option A, 45% B, 45% C
	(AltarUpgradeManager). Der Buchstabe steht im roten Trommel-Bereich der Säule, für
	alle vier Götter gleichzeitig sichtbar, damit der Spieler danach auswählen kann.
	Die Würfe sind pro Spieler unabhängig – zwei Spieler sehen an derselben Säule
	unterschiedliche Buchstaben.

	EIN Klick auf die Götter-Taste OPFERT direkt für diesen Gott (aktiviert dessen
	ausgewürfelte Gunst fürs nächste Rennen) – kein Detail-Panel, kein separater
	"Opfern"-Knopf. MEHRERE Götter dürfen gleichzeitig aktiv sein; jede aktive Säule
	brennt. Preis und Regeln macht komplett der host-autoritative AltarUpgradeManager:

	  * C-Gaben (passive Boni) stapeln unbegrenzt – notfalls alle vier gleichzeitig.
	  * A/B-Gaben geben ein Start-Item, davon gibt es nur EINEN Platz. Ein zweiter
	    A/B-Gott ist deshalb ein GRATIS-Wechsel: der alte wird deaktiviert.
	  * Der Preis steigt mit der Anzahl schon aktiver Gaben (30/80/150/300 PG).

	Das leere Gold-Schild am Fuß jeder Säulen-Textur zeigt genau diesen Zustand an:
	"30 PG" (Preis), "Aktiv" (schon gekauft) oder "Wechseln" (gratis A/B-Tausch) –
	siehe PriceLabel(). Rot = zu wenig PG.

	KEIN eigener Hintergrund – nutzt den scrollenden Hintergrund vom GUI-Parent
	(LobbyBackgroundGUI). root ist daher transparent.

	KLICK-MUSTER (wichtig): In s&box werden fast durchsichtige Flächen NICHT
	zuverlässig getroffen. Deshalb sitzt der onclick + pointer-events:all + z-index
	IMMER auf dem sichtbaren Button selbst (der eine DECKENDE Button-Textur hat),
	nicht auf einem transparenten Overlay darüber – genau dasselbe Muster wie die
	funktionierenden Buttons in der LobbyGUI. Das Abdunkeln beim Hovern macht ein
	filter: brightness() und funktioniert damit unabhängig davon, ob genug PG da ist.

	Texturen (Säulen/Buttons/Icons) werden – wie in der LobbyGUI – per Code gesetzt
	(Style.SetBackgroundImage), damit "Image File"-Zuweisungen ohne ResourcePath
	trotzdem funktionieren. Der Screen-Zustand kommt aus dem host-autoritativen
	AltarUpgradeManager (aktive Götter + ausgewürfelte Gunst je Gott) und
	PublicityCurrencyManager (PG).
*@

<root>
	<div class="topbar">
		<!-- Zurück-Button: onclick sitzt direkt auf dem (deckenden) Button-Graphic. -->
		<div class="back-btn" onclick="@GoBack">
			<div class="btn-label">Zurück</div>
		</div>
		<div class="pg-display">Publikumsgunst: @LocalPG PG</div>
		@if ( DebugFreeUpgrades )
		{
			<div class="debug-badge">DEBUG: Upgrades gratis</div>
		}
	</div>

	<div class="altar-row">
		@for ( int i = 0; i < PowerCount; i++ )
		{
			int idx = i;
			var power = Powers[idx];
			var god = AltarUpgradeManager.ParseGod( power.Name );
			bool active = AltarUpgradeManager.LocalIsActive( god );

			<div class="pillar-col">
				<div class="pillar @( active ? "active" : "" )">
					<div class="pillar-icon"></div>
					<!-- Ausgewürfelte Gunst dieses Gottes für DIESEN Spieler (A/B/C),
					     liegt im roten Trommel-Bereich der Säulen-Textur. -->
					<div class="pillar-option">@OptionLetter( god )</div>
					<!-- Preis/Status im leeren Gold-Schild am Säulenfuß (Teil der Textur). -->
					<div class="pillar-price @PriceClass( god )">@PriceLabel( god )</div>
				</div>

				<!-- EIN Button je Gott: Klick opfert direkt für diesen Gott. onclick auf dem
				     deckenden Button selbst -> zuverlässig klickbar; dunkelt beim Hovern ab. -->
				<div class="pillar-btn @( active ? "owned" : "" )" onclick="@(() => BuyGod( idx ))">
					<div class="btn-label">@power.Name</div>
				</div>
			</div>
		}
	</div>
</root>

<style>
	root {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		font-family: Arial;
		color: rgba(74, 44, 12, 1);
		/* Über dem LobbyBackgroundGUI (z-index 0), damit der scrollende Hintergrund
		   dahinter sichtbar bleibt (sonst nur die graue Kamera-Clearfarbe). */
		z-index: 1;
	}

	/* ----------------------------- Topbar ----------------------------- */
	.topbar {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 200px;
	}

	/* Zurück-Button: sichtbarer Button mit deckender Textur = zuverlässig klickbar
	   (gleiches Muster wie die funktionierenden LobbyGUI-Buttons). */
	.back-btn {
		position: absolute;
		left: 40px;
		top: 40px;
		width: 320px;
		height: 120px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		pointer-events: all;
		z-index: 20;
		transition: transform 0.1s ease;
	}

	.back-btn:hover {
		filter: brightness( 0.85 );
		transform: scale( 1.04 );
	}

	.pg-display {
		position: absolute;
		right: 48px;
		top: 56px;
		font-size: 40px;
		font-weight: bold;
		color: rgba(250, 230, 150, 1);
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
	}

	/* DEBUG-Hinweis: nur sichtbar, wenn die Gratis-Upgrades aktiv sind. */
	.debug-badge {
		position: absolute;
		right: 48px;
		top: 108px;
		padding: 4px 16px;
		font-size: 24px;
		font-weight: bold;
		color: rgba(30, 18, 6, 1);
		background-color: rgba(255, 120, 70, 0.95);
		border-radius: 8px;
	}

	/* ----------------------------- Säulen-Reihe ----------------------------- */
	.altar-row {
		position: absolute;
		left: 0;
		top: 180px;
		width: 100%;
		flex-direction: row;
		justify-content: center;
		align-items: flex-start;
		gap: 48px;
	}

	.pillar-col {
		flex-direction: column;
		align-items: center;
		gap: 16px;
		width: 380px;
	}

	.pillar {
		width: 380px;
		height: 620px;
		position: relative;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		pointer-events: none;
	}

	/* Voll-Overlay: das God-Power-Icon liegt auf der gleichen Leinwandgröße wie
	   die Säule -> es landet automatisch mittig im Kreis. */
	.pillar-icon {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		pointer-events: none;
	}

	/* ----------------------------- Options-Label ----------------------------- */
	/* Sitzt auf dem roten Trommel-Band der Säulen-Textur. Die Werte sind aus
	   AltarSäule_Aktiv/Inaktiv.png (437x804) ausgemessen: das rote Band läuft von
	   58.1% bis 76.5% der Höhe und von 12% bis 89% der Breite. Prozente statt Pixel,
	   damit es an der Säule klebt, falls .pillar mal andere Maße bekommt. */
	.pillar-option {
		position: absolute;
		left: 12%;
		top: 58%;
		width: 77%;
		height: 18.4%;
		align-items: center;
		justify-content: center;
		font-size: 72px;
		font-weight: bold;
		color: rgba(250, 230, 150, 1);
		text-align: center;
		text-shadow: 3px 3px 5px rgba(0, 0, 0, 0.85);
		pointer-events: none;
	}

	/* ----------------------------- Preis-Schild ----------------------------- */
	/* Sitzt im leeren Gold-Schild am Fuß der Säulen-Textur. Wie beim Options-Label
	   sind die Werte aus AltarSäule_Aktiv/Inaktiv.png (437x804) ausgemessen: die
	   Innenfläche des Schilds (ohne schwarzen Rand) läuft von 89% bis 98.5% der Höhe
	   und von 24% bis 76% der Breite. Prozente statt Pixel, damit es an der Säule
	   klebt, falls .pillar mal andere Maße bekommt. */
	.pillar-price {
		position: absolute;
		left: 24%;
		top: 89%;
		width: 52%;
		height: 9.5%;
		align-items: center;
		justify-content: center;
		font-size: 32px;
		font-weight: bold;
		color: rgba(74, 44, 12, 1);
		text-align: center;
		pointer-events: none;
	}

	/* Schon gekauft: dieselbe Gunst nochmal kaufen geht nicht, also grün statt Preis. */
	.pillar-price.owned {
		color: rgba(24, 84, 32, 1);
	}

	/* Gratis-Wechsel des A/B-Item-Platzes – hebt sich vom normalen Preis ab. */
	.pillar-price.swap {
		color: rgba(150, 70, 10, 1);
	}

	/* Zu wenig PG: Preis bleibt lesbar, aber klar als "geht nicht" markiert. */
	.pillar-price.locked {
		color: rgba(140, 30, 24, 1);
	}

	/* ----------------------------- Götter-Buttons ----------------------------- */
	/* Der sichtbare Button IST die Klickfläche (= Opfern für diesen Gott). Deckende
	   Button-Textur (per Code gesetzt) -> s&box trifft ihn zuverlässig. */
	.pillar-btn {
		position: relative;
		width: 250px;
		height: 92px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		pointer-events: all;
		z-index: 20;
		transition: transform 0.1s ease;
	}

	/* Hover: den ganzen Button abdunkeln – funktioniert unabhängig davon, ob genug
	   PG vorhanden ist. */
	.pillar-btn:hover {
		filter: brightness( 0.82 );
		transform: scale( 1.05 );
	}

	/* Der aktuell gekaufte Gott: goldener Glow als Besitz-Feedback. */
	.pillar-btn.owned {
		box-shadow: 0px 0px 22px rgba(255, 210, 90, 0.95);
	}

	.btn-label {
		font-size: 36px;
		font-weight: bold;
		color: rgba(74, 44, 12, 1);
		text-align: center;
		pointer-events: none;   /* nie Klicks abfangen -> gehen an den Button */
	}
</style>

@code
{
	// ====================================================================
	//  EDITOR-SLOTS — Texturen aus "Assets/UI/2D Lobby UI/Altar UI"
	// ====================================================================

	[Group( "Altar UI – Säulen" )]
	[Property] public Texture PillarActive { get; set; }    // AltarSäule_Aktiv (Kerze brennt)
	[Group( "Altar UI – Säulen" )]
	[Property] public Texture PillarInactive { get; set; }  // AltarSäule_Inaktiv (Kerze aus)

	[Group( "Altar UI – Buttons" )]
	[Property] public Texture Button { get; set; }          // Button_AltarMenu (Zurück + pro Säule)

	// Eine Säule pro Eintrag. Standard: die 4 Götter – im Inspector nur noch das
	// jeweilige Icon (z.B. Maat_Altar) zuweisen, Namen anpassen oder umsortieren.
	[Group( "Altar UI – Götter" )]
	[Property] public List<AltarPower> Powers { get; set; } = new()
	{
		new AltarPower { Name = "Maat" },
		new AltarPower { Name = "Dionysos" },
		new AltarPower { Name = "Laverna" },
		new AltarPower { Name = "Taranis" },
	};

	// ====================================================================
	//  DEBUG
	// ====================================================================

	// Wenn aktiv, kostet JEDES Upgrade 0 PG (schnelles Testen). Wird jeden Frame in
	// die statische AltarUpgradeManager.DebugFreeUpgrades gespiegelt; der Host (die
	// Autorität) erzwingt es dann auch wirklich beim Kauf. Standard: aus.
	[Group( "Altar UI – Debug" )]
	[Property] public bool DebugFreeUpgrades { get; set; } = false;

	// ====================================================================
	//  Abgeleitete Werte aus den host-autoritativen Managern
	// ====================================================================

	int PowerCount => Powers?.Count ?? 0;

	int LocalPG => PublicityCurrencyManager.LocalCurrency;
	ulong LocalSteamId => PublicityCurrencyManager.LocalSteamId;

	// Buchstabe der Gunst, die dieser Gott für DIESEN Spieler ausgewürfelt hat (A/B/C).
	// Leer, solange der Host noch nicht gewürfelt hat – dann bleibt das rote Band leer,
	// statt einen falschen Buchstaben zu zeigen.
	string OptionLetter( GodId god )
	{
		var option = AltarUpgradeManager.LocalOption( god );
		return option == AltarOption.None ? "" : option.ToString();
	}

	// ====================================================================
	//  Preis-Schild am Säulenfuß
	// ====================================================================

	// Solange der Host für diesen Gott noch nichts gewürfelt hat, ist JEDE Preisaussage
	// geraten: ein frisch verbundener Client hat noch einen leeren Mirror UND 0 PG, und
	// beides zusammen sieht für CostForGod aus wie "pleite, also erste Gunst gratis" –
	// das Schild würde kurz "Gratis" blinken und dann auf "30 PG" springen. Das rote Band
	// bleibt im selben Zustand leer (OptionLetter), also bleibt das Schild es auch.
	bool Rolled( GodId god ) => AltarUpgradeManager.LocalOption( god ) != AltarOption.None;

	// Was im leeren Gold-Schild steht. Reine Anzeige des Zustands, den der
	// AltarUpgradeManager ohnehin schon berechnet – hier wird NICHTS neu entschieden,
	// sonst könnte das Schild einen anderen Preis zeigen als der Host abbucht.
	string PriceLabel( GodId god )
	{
		if ( god == GodId.None || !Rolled( god ) ) return "";
		if ( AltarUpgradeManager.LocalIsActive( god ) ) return "Aktiv";
		if ( AltarUpgradeManager.LocalIsFreeSwap( god ) ) return "Wechseln";

		int cost = AltarUpgradeManager.CostForGod( LocalSteamId, god );
		if ( cost < 0 ) return "";        // alle Plätze belegt – hier gibt es nichts zu kaufen
		if ( cost == 0 ) return "Gratis"; // Debug-Modus oder die Pleite-Regel (erste Gunst frei)
		return $"{cost} PG";
	}

	// Einfärbung passend zum Text: gekauft / Gratis-Wechsel / zu teuer / normal.
	string PriceClass( GodId god )
	{
		if ( god == GodId.None || !Rolled( god ) ) return "";
		if ( AltarUpgradeManager.LocalIsActive( god ) ) return "owned";
		if ( AltarUpgradeManager.LocalIsFreeSwap( god ) ) return "swap";

		int cost = AltarUpgradeManager.CostForGod( LocalSteamId, god );
		return cost > 0 && LocalPG < cost ? "locked" : "";
	}

	// ====================================================================
	//  Interaktion
	// ====================================================================

	// Direktkauf: Ein Klick auf einen Götter-Button opfert sofort für diesen Gott und
	// aktiviert dessen ausgewürfelte Gunst zusätzlich zu allem, was schon aktiv ist.
	// Der Host prüft Kosten/PG erneut autoritativ; die lokalen Guards sind nur für
	// sofortiges Feedback (kein Sound/RPC, wenn der Gott schon aktiv ist oder zu wenig
	// PG da sind). Kostet 0 PG, wenn es ein A/B-Wechsel ist – den alten A/B-Gott nimmt
	// dann der Host aus der aktiven Liste.
	void BuyGod( int index )
	{
		if ( index < 0 || index >= PowerCount ) return;

		var god = AltarUpgradeManager.ParseGod( Powers[index].Name );
		if ( god == GodId.None ) return;

		int cost = AltarUpgradeManager.CostForGod( LocalSteamId, god );
		if ( cost < 0 ) return;         // schon aktiv oder alle Plätze belegt
		if ( LocalPG < cost ) return;   // zu wenig PG (Host lehnt sonst ohnehin ab)

		LobbyUISFX.Instance?.PlayButtonSound();
		AltarUpgradeManager.Instance?.RequestPurchaseRpc( (int)god );
	}

	// Zurück zum Lobby-Screen (AltarGUI aus, LobbyGUI an). Zentral im LobbyManager.
	void GoBack()
	{
		LobbyUISFX.Instance?.PlayButtonSound();   // lokaler Klick-Sound (nur dieser Spieler)
		LobbyManager.Instance?.ShowLobby();
	}

	// ====================================================================
	//  Texturen per Code setzen (wie LobbyGUI; funktioniert mit "Image File")
	// ====================================================================

	protected override void OnTreeBuilt() => ApplyTextures();

	void ApplyTextures()
	{
		var root = Panel;
		if ( root is null ) return;

		SetBgAll( root, "back-btn", Button );
		SetBgAll( root, "pillar-btn", Button );

		// Säulen in DOM-Reihenfolge den Powers zuordnen (gleiche Reihenfolge wie die
		// for-Schleife im Markup). Jede GEKAUFTE Säule brennt – es können mehrere
		// gleichzeitig sein.
		var cols = FindByClass( root, "pillar-col" ).ToList();
		for ( int i = 0; i < cols.Count; i++ )
		{
			var pillar = FindByClass( cols[i], "pillar" ).FirstOrDefault();
			var icon = FindByClass( cols[i], "pillar-icon" ).FirstOrDefault();

			bool active = i < PowerCount
				&& AltarUpgradeManager.LocalIsActive( AltarUpgradeManager.ParseGod( Powers[i].Name ) );

			SetBg( pillar, active ? PillarActive : PillarInactive );
			if ( i < PowerCount )
				SetBg( icon, Powers[i].Icon );
		}
	}

	static void SetBgAll( Panel root, string cls, Texture tex )
	{
		if ( tex is null ) return;
		foreach ( var pnl in FindByClass( root, cls ) )
			pnl.Style.SetBackgroundImage( tex );
	}

	static void SetBg( Panel pnl, Texture tex )
	{
		if ( pnl is null || tex is null ) return;
		pnl.Style.SetBackgroundImage( tex );
	}

	// Alle Panels unter root (inkl. root) mit der CSS-Klasse cls.
	static IEnumerable<Panel> FindByClass( Panel root, string cls )
	{
		if ( root is null ) yield break;
		if ( root.HasClass( cls ) ) yield return root;
		foreach ( var child in root.Children )
			foreach ( var found in FindByClass( child, cls ) )
				yield return found;
	}

	protected override void OnTreeFirstBuilt()
	{
		if ( PillarActive is null || !PillarActive.IsValid )
			Log.Warning( "[AltarGUI] Textur fehlt/ungültig: PillarActive (AltarSäule_Aktiv)" );
		if ( PillarInactive is null || !PillarInactive.IsValid )
			Log.Warning( "[AltarGUI] Textur fehlt/ungültig: PillarInactive (AltarSäule_Inaktiv)" );
		if ( Button is null || !Button.IsValid )
			Log.Warning( "[AltarGUI] Textur fehlt/ungültig: Button (Button_AltarMenu)" );
		for ( int i = 0; i < PowerCount; i++ )
			if ( Powers[i].Icon is null || !Powers[i].Icon.IsValid )
				Log.Warning( $"[AltarGUI] Icon fehlt/ungültig für Power '{Powers[i].Name}'" );
	}

	protected override void OnUpdate()
	{
		// Maus sichtbar halten, damit die Buttons anklickbar sind (dieser Screen
		// läuft evtl. ohne aktiven LobbyGUIScreen, der das sonst setzt).
		Mouse.Visibility = MouseVisibility.Visible;

		// Debug-Schalter live in den (host-autoritativen) Manager spiegeln.
		AltarUpgradeManager.DebugFreeUpgrades = DebugFreeUpgrades;
	}

	// Rebuild, sobald sich die PG, die aktiven Götter oder ein ausgewürfelter Buchstabe
	// ändern (BuildHash wird jeden Frame geprüft). Buchstabe UND Aktiv-Flag müssen je
	// Gott mit rein: sonst bleibt das rote Band leer bzw. das Preis-Schild steht auf dem
	// alten Wert, bis zufällig etwas anderes den Hash ändert. LocalPG deckt zusätzlich
	// den Umschlag von "kaufbar" auf "locked" ab.
	protected override int BuildHash()
	{
		var hash = new HashCode();
		hash.Add( PowerCount );
		hash.Add( LocalPG );
		hash.Add( DebugFreeUpgrades );
		if ( Powers != null )
		{
			foreach ( var p in Powers )
			{
				var god = AltarUpgradeManager.ParseGod( p?.Name );
				hash.Add( p?.Name );
				hash.Add( (int)AltarUpgradeManager.LocalOption( god ) );
				hash.Add( AltarUpgradeManager.LocalIsActive( god ) );
			}
		}
		return hash.ToHashCode();
	}
}
