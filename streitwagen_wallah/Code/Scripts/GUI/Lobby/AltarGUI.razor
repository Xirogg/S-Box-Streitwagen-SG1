@using Sandbox;
@using Sandbox.UI;
@using System;
@using System.Linq;
@using System.Collections.Generic;
@inherits PanelComponent
@namespace Sandbox

@*
	OPFERALTAR-SCREEN  (Streitwagen-Wallah)

	Vier Altar-Säulen (ein Gott je Säule). Der Spieler kann für Publikumsgunst (PG)
	EINEN Gott bis Stufe 3 ausbauen (AltarUpgradeManager). Klick auf eine Götter-
	Taste wählt den Gott zur Ansicht; das Detail-Panel zeigt Stufe/Bonus/Kosten und
	den "Opfern"-Knopf. Der gekaufte Gott brennt (aktive Säule); ein Wechsel setzt den
	vorherigen Gott zurück.

	KEIN eigener Hintergrund – nutzt den scrollenden Hintergrund vom GUI-Parent
	(LobbyBackgroundGUI). root ist daher transparent.

	Texturen (Säulen/Buttons/Icons) werden – wie in der LobbyGUI – per Code gesetzt
	(Style.SetBackgroundImage), damit "Image File"-Zuweisungen ohne ResourcePath
	trotzdem funktionieren. Der Screen-Zustand kommt aus dem host-autoritativen
	AltarUpgradeManager (Auswahl/Stufe) und PublicityCurrencyManager (PG).
*@

<root>
	<div class="topbar">
		<div class="back-btn">
			<div class="btn-overlay" onclick="@GoBack">
				<div class="btn-label">Zurück</div>
			</div>
		</div>
		<div class="pg-display">Publikumsgunst: @LocalPG PG</div>
	</div>

	<div class="altar-row">
		@for ( int i = 0; i < PowerCount; i++ )
		{
			int idx = i;
			var power = Powers[idx];
			var god = AltarUpgradeManager.ParseGod( power.Name );
			int ownedLevel = ( god == OwnedGod && OwnedGod != GodId.None ) ? OwnedLevel : 0;

			<div class="pillar-col @( idx == SelectedIndex ? "viewing" : "" )">
				<div class="pillar @( god == OwnedGod && OwnedGod != GodId.None ? "active" : "" )">
					<div class="pillar-icon"></div>
				</div>

				<div class="level-pips">
					@for ( int l = 1; l <= AltarUpgradeManager.MaxLevel; l++ )
					{
						<div class="pip @( l <= ownedLevel ? "on" : "" )"></div>
					}
				</div>

				<div class="pillar-btn">
					<div class="btn-overlay god-btn" onclick="@(() => Select( idx ))">
						<div class="btn-label">@power.Name</div>
					</div>
				</div>
			</div>
		}
	</div>

	@if ( SelectedGod != GodId.None )
	{
		<div class="detail-wrap">
			<div class="detail">
				<div class="detail-title">@AltarUpgradeManager.DisplayName( SelectedGod )</div>
				<div class="detail-line">Aktuelle Stufe: @SelectedOwnedLevel / @AltarUpgradeManager.MaxLevel</div>
				<div class="detail-line">Stufe 3 Bonus: @AltarUpgradeManager.BonusText( SelectedGod )</div>

				@if ( SelectedCost < 0 )
				{
					<div class="detail-cost maxed">Maximal ausgebaut</div>
				}
				else
				{
					<div class="detail-cost">Stufe @NextLevelForSelected freischalten: <span class="cost-num">@CostLabel</span></div>

					@if ( IsSwitch )
					{
						<div class="detail-warn">Wechsel setzt @AltarUpgradeManager.DisplayName( OwnedGod ) zurück (keine Rückerstattung)!</div>
					}

					<div class="buy-btn @( CanAfford ? "" : "disabled" )">
						<div class="btn-overlay" onclick="@BuySelected">
							<div class="btn-label">Opfern</div>
						</div>
					</div>
				}
			</div>
		</div>
	}

	<!-- ======================= TEST-Button -> Lobby ======================= -->
	<!-- Klickfläche genau über dem "Zurück"-Button. Fängt dort per z-index den
	     Linksklick ab und wechselt über die vorhandene Logik zurück. Nur zum Testen. -->
	<div class="test-btn" onclick="@TestSwitchToLobby"></div>
</root>

<style>
	root {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		font-family: Arial;
		color: rgba(74, 44, 12, 1);
		/* Über dem LobbyBackgroundGUI (z-index 0), damit der scrollende Hintergrund
		   dahinter sichtbar bleibt (sonst nur die graue Kamera-Clearfarbe). */
		z-index: 1;
	}

	/* ----------------------------- Topbar ----------------------------- */
	.topbar {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 200px;
	}

	.back-btn {
		position: absolute;
		left: 40px;
		top: 40px;
		width: 320px;
		height: 120px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
	}

	.pg-display {
		position: absolute;
		right: 48px;
		top: 56px;
		font-size: 40px;
		font-weight: bold;
		color: rgba(250, 230, 150, 1);
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
	}

	/* ----------------------------- Säulen-Reihe ----------------------------- */
	.altar-row {
		position: absolute;
		left: 0;
		top: 180px;
		width: 100%;
		flex-direction: row;
		justify-content: center;
		align-items: flex-start;
		gap: 48px;
	}

	.pillar-col {
		flex-direction: column;
		align-items: center;
		gap: 16px;
		width: 380px;
		transition: transform 0.12s ease;
	}

	/* Der aktuell zur Ansicht gewählte Gott wird leicht hervorgehoben. */
	.pillar-col.viewing {
		transform: scale( 1.04 );
	}

	.pillar {
		width: 380px;
		height: 620px;
		position: relative;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		transition: transform 0.12s ease;
	}

	/* Voll-Overlay: das God-Power-Icon liegt auf der gleichen Leinwandgröße wie
	   die Säule -> es landet automatisch mittig im Kreis. */
	.pillar-icon {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		pointer-events: none;
	}

	/* ----------------------------- Stufen-Pips ----------------------------- */
	.level-pips {
		flex-direction: row;
		gap: 12px;
		justify-content: center;
		align-items: center;
		height: 28px;
	}

	.pip {
		width: 26px;
		height: 26px;
		border-radius: 26px;
		background-color: rgba(0, 0, 0, 0.35);
		border: 2px solid rgba(74, 44, 12, 0.8);
	}

	.pip.on {
		background-color: rgba(255, 190, 40, 1);
		border-color: rgba(120, 70, 10, 1);
	}

	/* ----------------------------- Götter-Buttons ----------------------------- */
	.pillar-btn {
		position: relative;
		width: 250px;
		height: 92px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
	}

	/* Klick-/Hover-Fläche über der Button-Grafik. Gleicher Hover-"Shader" wie die
	   LobbyGUI-Buttons (.altar-btn/.ready-btn ...): leicht abdunkeln, indem eine
	   transparente Fläche beim Hovern von rgba(0,0,0,0.04) auf rgba(0,0,0,0.2) blendet. */
	.btn-overlay {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		background-color: rgba(0, 0, 0, 0.04);
		transition: background-color 0.1s ease;
	}

	.btn-overlay:hover {
		background-color: rgba(0, 0, 0, 0.2);
	}

	.btn-label {
		font-size: 36px;
		font-weight: bold;
		color: rgba(74, 44, 12, 1);
		text-align: center;
	}

	/* ----------------------------- Detail-/Kauf-Panel ----------------------------- */
	.detail-wrap {
		position: absolute;
		left: 0;
		bottom: 36px;
		width: 100%;
		flex-direction: row;
		justify-content: center;
		z-index: 5;
	}

	.detail {
		flex-direction: column;
		align-items: center;
		gap: 12px;
		min-width: 620px;
		padding: 24px 40px;
		background-color: rgba(30, 18, 6, 0.92);
		border: 3px solid rgba(255, 190, 40, 0.85);
		border-radius: 14px;
	}

	.detail-title {
		font-size: 46px;
		font-weight: bold;
		color: rgba(255, 210, 90, 1);
	}

	.detail-line {
		font-size: 30px;
		color: rgba(240, 230, 210, 1);
	}

	.detail-cost {
		font-size: 32px;
		color: rgba(240, 230, 210, 1);
		margin-top: 6px;
	}

	.detail-cost .cost-num {
		font-weight: bold;
		color: rgba(255, 210, 90, 1);
	}

	.detail-cost.maxed {
		color: rgba(150, 220, 150, 1);
		font-weight: bold;
	}

	.detail-warn {
		font-size: 26px;
		color: rgba(255, 130, 110, 1);
		text-align: center;
	}

	.buy-btn {
		position: relative;
		width: 260px;
		height: 92px;
		margin-top: 10px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
	}

	.buy-btn.disabled {
		filter: brightness( 0.45 );
	}

	/* Deaktiviert: kein Klick-Cursor und kein Hover-Abdunkeln. */
	.buy-btn.disabled .btn-overlay {
		cursor: default;
	}

	.buy-btn.disabled .btn-overlay:hover {
		background-color: rgba(0, 0, 0, 0.04);
	}

	/* ----------------------------- TEST-Button ----------------------------- */
	.test-btn {
		position: absolute;
		left: 40px;
		top: 40px;
		width: 320px;
		height: 120px;
		z-index: 100;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(40, 90, 180, 0.06);
		transition: background-color 0.1s ease;
	}

	.test-btn:hover {
		background-color: rgba(0, 0, 0, 0.2);
	}
</style>

@code
{
	// ====================================================================
	//  EDITOR-SLOTS — Texturen aus "Assets/UI/2D Lobby UI/Altar UI"
	// ====================================================================

	[Group( "Altar UI – Säulen" )]
	[Property] public Texture PillarActive { get; set; }    // AltarSäule_Aktiv (Kerze brennt)
	[Group( "Altar UI – Säulen" )]
	[Property] public Texture PillarInactive { get; set; }  // AltarSäule_Inaktiv (Kerze aus)

	[Group( "Altar UI – Buttons" )]
	[Property] public Texture Button { get; set; }          // Button_AltarMenu (Zurück + pro Säule + Opfern)

	// Eine Säule pro Eintrag. Standard: die 4 Götter – im Inspector nur noch das
	// jeweilige Icon (z.B. Maat_Altar) zuweisen, Namen anpassen oder umsortieren.
	[Group( "Altar UI – Götter" )]
	[Property] public List<AltarPower> Powers { get; set; } = new()
	{
		new AltarPower { Name = "Maat" },
		new AltarPower { Name = "Dionysos" },
		new AltarPower { Name = "Laverna" },
		new AltarPower { Name = "Taranis" },
	};

	// ====================================================================
	//  Lokaler UI-Zustand (welcher Gott wird gerade betrachtet – pro Client)
	// ====================================================================

	private int SelectedIndex { get; set; } = -1;   // -1 = keine Säule betrachtet

	int PowerCount => Powers?.Count ?? 0;

	// ---- Abgeleitete Werte aus den host-autoritativen Managern ----

	int LocalPG => PublicityCurrencyManager.LocalCurrency;
	ulong LocalSteamId => PublicityCurrencyManager.LocalSteamId;

	GodId OwnedGod => AltarUpgradeManager.LocalChoice.God;
	int OwnedLevel => AltarUpgradeManager.LocalChoice.Level;

	GodId SelectedGod => ( SelectedIndex >= 0 && SelectedIndex < PowerCount )
		? AltarUpgradeManager.ParseGod( Powers[SelectedIndex].Name )
		: GodId.None;

	int SelectedOwnedLevel => ( SelectedGod == OwnedGod && OwnedGod != GodId.None ) ? OwnedLevel : 0;

	// -1 = bereits maximal ausgebaut; 0 = gratis; sonst PG-Preis der nächsten Stufe.
	int SelectedCost => SelectedGod == GodId.None
		? -1
		: AltarUpgradeManager.CostForNextLevel( LocalSteamId, SelectedGod );

	int NextLevelForSelected => ( SelectedGod == OwnedGod && OwnedGod != GodId.None ) ? OwnedLevel + 1 : 1;

	bool IsSwitch => OwnedGod != GodId.None && SelectedGod != GodId.None && SelectedGod != OwnedGod;

	bool CanAfford => SelectedCost >= 0 && LocalPG >= SelectedCost;

	string CostLabel => SelectedCost == 0 ? "Gratis" : $"{SelectedCost} PG";

	// ====================================================================
	//  Interaktion
	// ====================================================================

	void Select( int index )
	{
		LobbyUISFX.Instance?.PlayButtonSound();
		// Erneuter Klick auf die betrachtete Säule schließt das Detail-Panel wieder.
		SelectedIndex = (SelectedIndex == index) ? -1 : index;
	}

	// Kauf/Upgrade des gerade betrachteten Gottes. Host prüft Kosten/PG erneut
	// autoritativ; die lokalen Guards sind nur für sofortiges UI-Feedback.
	void BuySelected()
	{
		if ( SelectedGod == GodId.None ) return;
		if ( SelectedCost < 0 ) return;   // maxed
		if ( !CanAfford ) return;         // zu wenig PG

		LobbyUISFX.Instance?.PlayButtonSound();
		AltarUpgradeManager.Instance?.RequestPurchaseRpc( (int)SelectedGod );
	}

	// Zurück zum Lobby-Screen (AltarGUI aus, LobbyGUI an). Zentral im LobbyManager.
	void GoBack() => LobbyManager.Instance?.ShowLobby();

	// TEST-Button: Ein Linksklick irgendwo auf dem Vollbild-Button wechselt zurück
	// auf den Lobby-Screen (gleiche Umschalt-Logik wie GoBack).
	void TestSwitchToLobby()
	{
		LobbyUISFX.Instance?.PlayButtonSound();   // lokaler Klick-Sound (nur dieser Spieler)
		LobbyManager.Instance?.ShowLobby();
	}

	// ====================================================================
	//  Texturen per Code setzen (wie LobbyGUI; funktioniert mit "Image File")
	// ====================================================================

	protected override void OnTreeBuilt() => ApplyTextures();

	void ApplyTextures()
	{
		var root = Panel;
		if ( root is null ) return;

		SetBgAll( root, "back-btn", Button );
		SetBgAll( root, "pillar-btn", Button );
		SetBgAll( root, "buy-btn", Button );

		var ownedGod = OwnedGod;

		// Säulen in DOM-Reihenfolge den Powers zuordnen (gleiche Reihenfolge wie die
		// for-Schleife im Markup). Die "aktive" (brennende) Säule ist der GEKAUFTE Gott.
		var cols = FindByClass( root, "pillar-col" ).ToList();
		for ( int i = 0; i < cols.Count; i++ )
		{
			var pillar = FindByClass( cols[i], "pillar" ).FirstOrDefault();
			var icon = FindByClass( cols[i], "pillar-icon" ).FirstOrDefault();

			bool owned = i < PowerCount
				&& ownedGod != GodId.None
				&& AltarUpgradeManager.ParseGod( Powers[i].Name ) == ownedGod;

			SetBg( pillar, owned ? PillarActive : PillarInactive );
			if ( i < PowerCount )
				SetBg( icon, Powers[i].Icon );
		}
	}

	static void SetBgAll( Panel root, string cls, Texture tex )
	{
		if ( tex is null ) return;
		foreach ( var pnl in FindByClass( root, cls ) )
			pnl.Style.SetBackgroundImage( tex );
	}

	static void SetBg( Panel pnl, Texture tex )
	{
		if ( pnl is null || tex is null ) return;
		pnl.Style.SetBackgroundImage( tex );
	}

	// Alle Panels unter root (inkl. root) mit der CSS-Klasse cls.
	static IEnumerable<Panel> FindByClass( Panel root, string cls )
	{
		if ( root is null ) yield break;
		if ( root.HasClass( cls ) ) yield return root;
		foreach ( var child in root.Children )
			foreach ( var found in FindByClass( child, cls ) )
				yield return found;
	}

	protected override void OnTreeFirstBuilt()
	{
		if ( PillarActive is null || !PillarActive.IsValid )
			Log.Warning( "[AltarGUI] Textur fehlt/ungültig: PillarActive (AltarSäule_Aktiv)" );
		if ( PillarInactive is null || !PillarInactive.IsValid )
			Log.Warning( "[AltarGUI] Textur fehlt/ungültig: PillarInactive (AltarSäule_Inaktiv)" );
		if ( Button is null || !Button.IsValid )
			Log.Warning( "[AltarGUI] Textur fehlt/ungültig: Button (Button_AltarMenu)" );
		for ( int i = 0; i < PowerCount; i++ )
			if ( Powers[i].Icon is null || !Powers[i].Icon.IsValid )
				Log.Warning( $"[AltarGUI] Icon fehlt/ungültig für Power '{Powers[i].Name}'" );
	}

	protected override void OnUpdate()
	{
		// Maus sichtbar halten, damit die Buttons anklickbar sind (dieser Screen
		// läuft evtl. ohne aktiven LobbyGUIScreen, der das sonst setzt).
		Mouse.Visibility = MouseVisibility.Visible;
	}

	// Rebuild, sobald sich die betrachtete Säule, die PG oder die gekaufte
	// Auswahl/Stufe ändern (BuildHash wird jeden Frame geprüft).
	protected override int BuildHash()
	{
		var choice = AltarUpgradeManager.LocalChoice;
		var hash = new HashCode();
		hash.Add( SelectedIndex );
		hash.Add( PowerCount );
		hash.Add( LocalPG );
		hash.Add( (int)choice.God );
		hash.Add( choice.Level );
		if ( Powers != null )
			foreach ( var p in Powers )
				hash.Add( p?.Name );
		return hash.ToHashCode();
	}
}
