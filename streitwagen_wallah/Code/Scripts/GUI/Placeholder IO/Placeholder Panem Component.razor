@using System;
@using System.Collections.Generic;
@using System.Linq;
@using Sandbox;
@using Sandbox.UI;
@using LapSystem;
@using LapSystem.Rankings;
@inherits PanelComponent
@namespace Sandbox

<root>
	@if ( !IsProxy )
	{
		<div class="lap">@LapText</div>
		<div class="hpbar" style="background-image: url(@HpOutlinePath);">
			<div class="hp-fill-clip" style="width: @(HPPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;">
				<div class="hp-fill" style="background-image: url(@HpFillPath);"></div>
			</div>
		</div>
		<div class="position" style="color: @PositionColor;">@PositionText</div>
		<div class="currency">@LocalCurrency</div>

		<div class="item-slot" style="background-image: url(@ItemSlotPath);">
			@if ( ShowItemIcon )
			{
				<div class="item-icon" style="background-image: url(@CurrentItemIconPath);"></div>
			}
		</div>

		@if ( ShowPowerMessage )
		{
			<div class="power-message">@PowerMessage</div>
		}

		@if ( ShowCountdown )
		{
			<div class="countdown">@CountdownDisplay</div>
		}

		@if ( ShowFinishMessage )
		{
			<div class="finish-overlay">
				<div class="finish-box">
					<div class="finish-text" style="color: @FinishColour;">@FinishMessage</div>

					<div class="leaderboard">
						@foreach ( var e in FinishedEntries )
						{
							<div class="lb-row">
								<span class="lb-pos" style="color: @LeaderboardColour( e.FinishOrder );">P@(e.FinishOrder)</span>
								<span class="lb-name">@NameFor( e )</span>
							</div>
						}

						@if ( RacingEntries.Count > 0 )
						{
							<div class="lb-section">Noch im Rennen</div>
							@foreach ( var e in RacingEntries )
							{
								<div class="lb-row lb-racing">
									<span class="lb-pos">–</span>
									<span class="lb-name">@NameFor( e )</span>
								</div>
							}
						}
					</div>

					@if ( RacingEntries.Count > 0 )
					{
						<div class="finish-waiting">Warte auf alle Spieler...</div>
					}
				</div>
			</div>
		}
	}
</root>

<style>
	root {
		position: relative;
		left: 132px;
		top: 132px;
		flex-direction: column;
		gap: 118px;
	}
	/* Lap counter, bottom-right. Pulled out of the root flow (was top-left)
	   so the HP bar can take over the top-left corner. Insets mirror the other
	   corner HUD elements: right: 132px like .item-slot, bottom: 132px like
	   .position. Label is just "0/3" now — the "Lap" prefix was dropped. */
	.lap {
		position: absolute;
		bottom: 132px;
		right: 132px;
		color: white;
		font-size: 132px;
		font-family: Arial;
		text-shadow: 0px 2px 2px black;
	}
	.currency {
		position: absolute;
		bottom: 290px;
		left: 132px;
		color: rgba(255, 220, 80, 1);
		font-size: 96px;
		font-family: Arial;
		text-shadow: 0px 2px 4px black;
	}
	/* Outline acts as the frame + empty-state visual. When the green shrinks
	   below 100% the brown interior of this texture shows through — no red. */
	.hpbar {
		width: 500px;
		height: 80px;
		/* background-image lives inline on the element so it can come from a
		   strongly-typed Texture property the asset pipeline can see. See the
		   HpOutlineTexture field below for the why. */
		background-size: 100% 100%;
		background-repeat: no-repeat;
		position: relative;
	}
	/* Clip box: its width is driven by HPPercent and it hides any green that
	   spills past the right edge. Inset to sit inside the outline's frame. */
	.hp-fill-clip {
		position: absolute;
		top: 18%;
		bottom: 18%;
		left: 4%;
		max-width: 92%;
		overflow: hidden;
		transition: width 0.15s linear;
	}
	/* The green is drawn at the FULL clip width (440px = 500 * 92%) so it
	   doesn't squish as HP drops — it just gets cut off on the right. */
	.hp-fill {
		position: absolute;
		top: 0;
		left: 0;
		width: 460px;
		height: 100%;
		/* background-image set inline from HpFillTexture.ResourcePath; see code block. */
		background-size: 100% 100%;
		background-repeat: no-repeat;
	}
	.position {
		position: absolute;
		bottom: 132px;
		left: 132px;
		color: white;
		font-size: 132px;
		font-family: Arial;
		text-shadow: 0px 2px 4px black;
	}
	/* Item box in the top-right. The ItemSlot texture is the always-visible frame;
	   the .item-icon child (only rendered while an item is held) draws the god-power
	   icon on top of it. Both use inline background-image sourced from strongly-typed
	   Texture properties so the asset pipeline bundles the PNGs for joining clients. */
	.item-slot {
		position: absolute;
		top: 0px;
		right: 132px;
		width: 192px;
		height: 192px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
	}
	.item-icon {
		position: absolute;
		top: 14%;
		left: 14%;
		width: 72%;
		height: 72%;
		background-size: contain;
		background-position: center;
		background-repeat: no-repeat;
	}
	.countdown {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		color: white;
		font-size: 256px;
		font-family: Arial;
		font-weight: bold;
		text-shadow: 0px 4px 8px black;
	}
	.power-message {
		position: absolute;
		top: 132px;
		left: 50%;
		transform: translateX(-50%);
		padding: 24px 48px;
		background-color: rgba(0, 0, 0, 0.45);
		border-radius: 16px;
		color: white;
		font-size: 64px;
		font-family: Arial;
		font-weight: bold;
		text-shadow: 0px 2px 4px black;
		white-space: nowrap;
	}

	.finish-overlay {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		justify-content: center;
		align-items: center;
	}

	.finish-box {
		padding: 48px 96px;
		background-color: rgba(200, 200, 200, 0.85);
		border-radius: 24px;
		border: 4px solid rgba(255, 255, 255, 0.4);
		flex-direction: column;
		align-items: center;
		gap: 16px;
	}

	.finish-text {
		font-size: 64px;
		font-family: Arial;
		font-weight: bold;
		color: rgba(30, 30, 30, 1);
		text-align: center;
	}

	.finish-waiting {
		font-size: 32px;
		font-family: Arial;
		color: rgba(60, 60, 60, 0.8);
	}

	/* Post-race leaderboard, shown inside the finish box once the local player has
	   finished. Rows come pre-sorted from RaceRankingManager: finishers first
	   (by FinishOrder), then anyone still racing. */
	.leaderboard {
		flex-direction: column;
		align-items: stretch;
		gap: 8px;
		margin-top: 8px;
		min-width: 560px;
	}

	.lb-row {
		flex-direction: row;
		align-items: center;
		gap: 20px;
		font-family: Arial;
		font-size: 40px;
		color: rgba(30, 30, 30, 1);
	}

	.lb-pos {
		font-weight: bold;
		width: 110px;
	}

	.lb-name {
		font-weight: bold;
	}

	/* "Noch im Rennen" separator above the still-racing players. */
	.lb-section {
		margin-top: 16px;
		font-family: Arial;
		font-size: 30px;
		font-weight: bold;
		color: rgba(70, 70, 70, 0.9);
	}

	/* Still-racing rows are dimmed so finishers read as the result. */
	.lb-racing {
		color: rgba(90, 90, 90, 1);
	}

	.lb-racing .lb-pos {
		color: rgba(120, 120, 120, 1);
	}
</style>

@code
{
	// HP-bar artwork. Held as strongly-typed Texture properties (not as hardcoded
	// "/ui/ingame gui/hp bar/..." URL strings in the stylesheet) so the s&box
	// asset-pipeline reference scanner can see them and actually bundle the PNGs
	// into the package joining clients download. A dynamic string built at
	// runtime is invisible to that scanner — the editor host had the files on
	// local disk and looked fine, but joiners would have ended up with blank
	// rectangles the same way the lobby track previews did. Assign these in the
	// inspector on the HUD prefab to the same PNGs the URL literals used to
	// point at (Assets/UI/InGame GUI/HP Bar/HP Outline.png and HP Green.png).
	[Property] public Texture HpOutlineTexture { get; set; }
	[Property] public Texture HpFillTexture { get; set; }

	string HpOutlinePath => HpOutlineTexture?.ResourcePath ?? "";
	string HpFillPath => HpFillTexture?.ResourcePath ?? "";

	// Item-slot artwork. Same strongly-typed-Texture reasoning as the HP bar above:
	// assign these in the inspector on the HUD prefab so the asset pipeline bundles the
	// PNGs for joining clients (a runtime-built URL string is invisible to the scanner).
	//   ItemSlotTexture  -> Assets/UI/InGame GUI/ItemSlot.png  (always-visible frame)
	//   the four *Icon    -> the matching god-power PNG shown inside the slot.
	[Group( "Item Slot" ), Property] public Texture ItemSlotTexture { get; set; }
	[Group( "Item Slot" ), Property] public Texture LavernaIcon { get; set; }
	[Group( "Item Slot" ), Property] public Texture TaranisIcon { get; set; }
	[Group( "Item Slot" ), Property] public Texture MaAtIcon { get; set; }
	[Group( "Item Slot" ), Property] public Texture DionysosIcon { get; set; }

	string ItemSlotPath => ItemSlotTexture?.ResourcePath ?? "";

	// Held key -> icon. Keys are free-form editor strings ("Dionysos", "Laverna",
	// "Ma'at", "Taranis"), so normalize to letters-only lowercase before matching:
	// "Ma'at" / "ma at" / "MaAt" all collapse to "maat".
	Texture IconForKey( string key )
	{
		if ( string.IsNullOrEmpty( key ) ) return null;
		var norm = new string( key.ToLowerInvariant().Where( char.IsLetter ).ToArray() );
		return norm switch
		{
			"laverna" => LavernaIcon,
			"taranis" => TaranisIcon,
			"maat" => MaAtIcon,
			"dionysos" => DionysosIcon,
			_ => null
		};
	}

	// Icon for the item the local player currently holds. "" when nothing is held or
	// the key has no assigned icon — the .item-icon div is then not rendered and only
	// the ItemSlot frame shows.
	string CurrentItemIconPath
	{
		get
		{
			var t = Items;
			if ( t is null || !t.HasItem ) return "";
			return IconForKey( t.HeldItemKey )?.ResourcePath ?? "";
		}
	}

	bool ShowItemIcon => !string.IsNullOrEmpty( CurrentItemIconPath );

	PlayerLapTracker Lap => Components.Get<PlayerLapTracker>( FindMode.EverythingInSelfAndAncestors );
	PlayerDamageSystem Damage => Components.Get<PlayerDamageSystem>( FindMode.EverythingInSelfAndAncestors );

	// The tracker can live on a sibling subtree of the UI panel (e.g. under
	// "Powers"). EverythingInSelfAndAncestors would miss it, so we walk up the
	// chain and search each level's whole subtree — same pattern ItemPrefab uses.
	PlayerItemTracker Items
	{
		get
		{
			var node = GameObject;
			while ( node.IsValid() )
			{
				var t = node.Components.Get<PlayerItemTracker>( FindMode.EverythingInSelfAndDescendants );
				if ( t is not null ) return t;
				node = node.Parent;
			}
			return null;
		}
	}

	// Same ancestor-walk pattern as Items — the notifier lives on the player root
	// (auto-created by GodPower.ResolveNotifier on first activation).
	GodPowerNotifier Notifier
	{
		get
		{
			var node = GameObject;
			while ( node.IsValid() )
			{
				var n = node.Components.Get<GodPowerNotifier>( FindMode.EverythingInSelfAndDescendants );
				if ( n is not null ) return n;
				node = node.Parent;
			}
			return null;
		}
	}

	string PowerMessage => Notifier?.CurrentText ?? "";
	bool ShowPowerMessage => !string.IsNullOrEmpty( PowerMessage );

	string LapText => Lap is null ? "-/-" : $"{Lap.CurrentLap}/{Lap.MaxLaps}";

	// Local player's PG total. Host pushes per-peer mirrors via RpcSetCurrency.
	int LocalCurrency => PublicityCurrencyManager.LocalCurrency;
	float HPPercent => Damage is null ? 0f
		: MathX.Clamp( Damage.CurrentHP / MathF.Max( Damage.MaxHP, 0.0001f ) * 100f, 0f, 100f );

	int CurrentPosition
	{
		get
		{
			var mgr = RaceRankingManager.Instance;
			if ( mgr is null || Lap is null ) return 0;
			foreach ( var entry in mgr.Rankings )
			{
				if ( entry.Tracker == Lap ) return entry.Position;
			}
			return 0;
		}
	}

	string PositionText => CurrentPosition > 0 ? CurrentPosition.ToString() : "-";

	string PositionColor => CurrentPosition switch
	{
		1 => "#2e7d32",
		2 => "#7cb342",
		3 => "#fdd835",
		_ => "#e53935"
	};

	LapSystem.RaceManager Race => LapSystem.RaceManager.Instance;

	bool ShowCountdown => Race is not null && Race.StartCountdownActive;

	string CountdownDisplay
	{
		get
		{
			if ( Race is null ) return "";
			float t = Race.StartCountdownTimeLeft;
			if ( t > 0f ) return MathF.Ceiling( t ).ToString( "0" );
			return "GO!";
		}
	}

	PlayerRankingEntry LocalRankingEntry
	{
		get
		{
			var mgr = RaceRankingManager.Instance;
			if ( mgr is null || Lap is null ) return null;
			foreach ( var entry in mgr.Rankings )
			{
				if ( entry.Tracker == Lap ) return entry;
			}
			return null;
		}
	}

	bool ShowFinishMessage => LocalRankingEntry is not null && LocalRankingEntry.RaceFinished;

	string FinishMessage
	{
		get
		{
			var entry = LocalRankingEntry;
			if ( entry is null ) return "";
			return entry.FinishOrder switch
			{
				1 => "Gewinner Gewinner  Huenchenabdendessen",
				2 => "Knapp daneben ist auch vorbei",
				3 => "Du bist eine Schande",
				_ => "Rennen beendet"
			};
		}
	}

	string FinishColour
	{
		get
		{
			var entry = LocalRankingEntry;
			if (entry is null) return "";
			return entry.FinishOrder switch
			{
				1 => "#2e7d32",
				2 => "#7cb342",
				3 => "#fdd835",
				_ => "#e53935"
			};
		}
	}

	// --- Post-race leaderboard ------------------------------------------------

	// The full ranking is already sorted by RaceRankingManager (finishers first by
	// FinishOrder, then racers by progress), so the UI only needs to split it.
	IReadOnlyList<PlayerRankingEntry> Board =>
		RaceRankingManager.Instance?.Rankings ?? (IReadOnlyList<PlayerRankingEntry>)System.Array.Empty<PlayerRankingEntry>();

	IEnumerable<PlayerRankingEntry> FinishedEntries => Board.Where( e => e.RaceFinished );
	List<PlayerRankingEntry> RacingEntries => Board.Where( e => !e.RaceFinished ).ToList();

	static string NameFor( PlayerRankingEntry e ) =>
		string.IsNullOrEmpty( e?.PlayerName ) ? "Spieler" : e.PlayerName;

	static string LeaderboardColour( int finishOrder ) => finishOrder switch
	{
		1 => "#2e7d32",
		2 => "#7cb342",
		3 => "#fdd835",
		_ => "#e53935"
	};

	// Folds the whole board into one int so BuildHash re-renders the leaderboard
	// when anyone finishes, changes order, or a name resolves.
	int BoardSignature
	{
		get
		{
			var mgr = RaceRankingManager.Instance;
			if ( mgr is null ) return 0;

			var hc = new System.HashCode();
			foreach ( var e in mgr.Rankings )
			{
				hc.Add( e.PlayerId );
				hc.Add( e.RaceFinished );
				hc.Add( e.FinishOrder );
				hc.Add( e.PlayerName );
			}
			return hc.ToHashCode();
		}
	}

	protected override int BuildHash() => System.HashCode.Combine(
		System.HashCode.Combine( IsProxy, Lap?.CurrentLap, Damage?.CurrentHP, CurrentPosition, Race?.StartCountdownTimeLeft, LocalRankingEntry?.RaceFinished, LocalRankingEntry?.FinishOrder, Items?.HeldItemKey ),
		System.HashCode.Combine( LocalCurrency, PowerMessage, BoardSignature )
	);
}
