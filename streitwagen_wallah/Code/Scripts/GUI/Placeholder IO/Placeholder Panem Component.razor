@using System;
@using Sandbox;
@using Sandbox.UI;
@using LapSystem;
@using LapSystem.Rankings;
@inherits PanelComponent
@namespace Sandbox

<root>
	@if ( !IsProxy )
	{
		<div class="lap">Lap @LapText</div>
		<div class="hpbar">
			<div class="hp-fill-clip" style="width: @(HPPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;">
				<div class="hp-fill"></div>
			</div>
		</div>
		<div class="position" style="color: @PositionColor;">@PositionText</div>
		<div class="currency">@LocalCurrency</div>

		<div class="item">Power: @ItemDisplay</div>

		@if ( ShowCountdown )
		{
			<div class="countdown">@CountdownDisplay</div>
		}

		@if ( ShowFinishMessage )
		{
			<div class="finish-overlay" style="color: @FinishColour;">
				<div class="finish-box" style="color: @FinishColour;">
					<div class="finish-text">@FinishMessage </div>
					<div class="finish-waiting">Warte auf alle Spieler...</div>
				</div>
			</div>
		}
	}
</root>

<style>
	root {
		position: relative;
		left: 132px;
		top: 132px;
		flex-direction: column;
		gap: 118px;
	}
	.lap {
		color: white;
		font-size: 132px;
		font-family: Arial;
		text-shadow: 0px 2px 2px black;
	}
	.currency {
		position: absolute;
		bottom: 290px;
		left: 132px;
		color: rgba(255, 220, 80, 1);
		font-size: 96px;
		font-family: Arial;
		text-shadow: 0px 2px 4px black;
	}
	/* Outline acts as the frame + empty-state visual. When the green shrinks
	   below 100% the brown interior of this texture shows through — no red. */
	.hpbar {
		width: 500px;
		height: 80px;
		background-image: url( "/ui/ingame gui/hp bar/hp outline.png" );
		background-size: 100% 100%;
		background-repeat: no-repeat;
		position: relative;
	}
	/* Clip box: its width is driven by HPPercent and it hides any green that
	   spills past the right edge. Inset to sit inside the outline's frame. */
	.hp-fill-clip {
		position: absolute;
		top: 18%;
		bottom: 18%;
		left: 4%;
		max-width: 92%;
		overflow: hidden;
		transition: width 0.15s linear;
	}
	/* The green is drawn at the FULL clip width (440px = 500 * 92%) so it
	   doesn't squish as HP drops — it just gets cut off on the right. */
	.hp-fill {
		position: absolute;
		top: 0;
		left: 0;
		width: 460px;
		height: 100%;
		background-image: url( "/ui/ingame gui/hp bar/hp green.png" );
		background-size: 100% 100%;
		background-repeat: no-repeat;
	}
	.position {
		position: absolute;
		bottom: 132px;
		left: 132px;
		color: white;
		font-size: 132px;
		font-family: Arial;
		text-shadow: 0px 2px 4px black;
	}
	.item {
		position: absolute;
		top: 0px;
		right: 132px;
		color: white;
		font-size: 64px;
		font-family: Arial;
		text-shadow: 0px 2px 4px black;
	}
	.countdown {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		color: white;
		font-size: 256px;
		font-family: Arial;
		font-weight: bold;
		text-shadow: 0px 4px 8px black;
	}

	.finish-overlay {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		justify-content: center;
		align-items: center;
	}

	.finish-box {
		padding: 48px 96px;
		background-color: rgba(200, 200, 200, 0.85);
		border-radius: 24px;
		border: 4px solid rgba(255, 255, 255, 0.4);
		flex-direction: column;
		align-items: center;
		gap: 16px;
	}

	.finish-text {
		font-size: 64px;
		font-family: Arial;
		font-weight: bold;
		color: rgba(30, 30, 30, 1);
		text-align: center;
	}

	.finish-waiting {
		font-size: 32px;
		font-family: Arial;
		color: rgba(60, 60, 60, 0.8);
	}
</style>

@code
{
	PlayerLapTracker Lap => Components.Get<PlayerLapTracker>( FindMode.EverythingInSelfAndAncestors );
	PlayerDamageSystem Damage => Components.Get<PlayerDamageSystem>( FindMode.EverythingInSelfAndAncestors );

	// The tracker can live on a sibling subtree of the UI panel (e.g. under
	// "Powers"). EverythingInSelfAndAncestors would miss it, so we walk up the
	// chain and search each level's whole subtree — same pattern ItemPrefab uses.
	PlayerItemTracker Items
	{
		get
		{
			var node = GameObject;
			while ( node.IsValid() )
			{
				var t = node.Components.Get<PlayerItemTracker>( FindMode.EverythingInSelfAndDescendants );
				if ( t is not null ) return t;
				node = node.Parent;
			}
			return null;
		}
	}

	// Top-right "Power:" label. Shows the first two letters of the held item key
	// (e.g. "dionysos" -> "DI", "ma at" -> "MA"), or "none" when empty.
	string ItemDisplay
	{
		get
		{
			var t = Items;
			if ( t is null || !t.HasItem ) return "none";

			var key = ( t.HeldItemKey ?? "" ).Replace( " ", "" );
			if ( string.IsNullOrEmpty( key ) ) return "none";

			var two = key.Length >= 2 ? key.Substring( 0, 2 ) : key;
			return two.ToUpperInvariant();
		}
	}

	string LapText => Lap is null ? "-/-" : $"{Lap.CurrentLap}/{Lap.MaxLaps}";

	// Local player's PG total. Host pushes per-peer mirrors via RpcSetCurrency.
	int LocalCurrency => PublicityCurrencyManager.LocalCurrency;
	float HPPercent => Damage is null ? 0f
		: MathX.Clamp( Damage.CurrentHP / MathF.Max( Damage.MaxHP, 0.0001f ) * 100f, 0f, 100f );

	int CurrentPosition
	{
		get
		{
			var mgr = RaceRankingManager.Instance;
			if ( mgr is null || Lap is null ) return 0;
			foreach ( var entry in mgr.Rankings )
			{
				if ( entry.Tracker == Lap ) return entry.Position;
			}
			return 0;
		}
	}

	string PositionText => CurrentPosition > 0 ? CurrentPosition.ToString() : "-";

	string PositionColor => CurrentPosition switch
	{
		1 => "#2e7d32",
		2 => "#7cb342",
		3 => "#fdd835",
		_ => "#e53935"
	};

	LapSystem.RaceManager Race => LapSystem.RaceManager.Instance;

	bool ShowCountdown => Race is not null && Race.StartCountdownActive;

	string CountdownDisplay
	{
		get
		{
			if ( Race is null ) return "";
			float t = Race.StartCountdownTimeLeft;
			if ( t > 0f ) return MathF.Ceiling( t ).ToString( "0" );
			return "GO!";
		}
	}

	PlayerRankingEntry LocalRankingEntry
	{
		get
		{
			var mgr = RaceRankingManager.Instance;
			if ( mgr is null || Lap is null ) return null;
			foreach ( var entry in mgr.Rankings )
			{
				if ( entry.Tracker == Lap ) return entry;
			}
			return null;
		}
	}

	bool ShowFinishMessage => LocalRankingEntry is not null && LocalRankingEntry.RaceFinished;

	string FinishMessage
	{
		get
		{
			var entry = LocalRankingEntry;
			if ( entry is null ) return "";
			return entry.FinishOrder switch
			{
				1 => "Gewinner Gewinner  Huenchenabdendessen",
				2 => "Knapp daneben ist auch vorbei",
				3 => "Du bist eine Schande",
				_ => "Rennen beendet"
			};
		}
	}

	string FinishColour
	{
		get
		{
			var entry = LocalRankingEntry;
			if (entry is null) return "";
			return entry.FinishOrder switch
			{
				1 => "#2e7d32",
				2 => "#7cb342",
				3 => "#fdd835",
				_ => "#e53935"
			};
		}
	}

	protected override int BuildHash() => System.HashCode.Combine(
		System.HashCode.Combine( IsProxy, Lap?.CurrentLap, Damage?.CurrentHP, CurrentPosition, Race?.StartCountdownTimeLeft, LocalRankingEntry?.RaceFinished, LocalRankingEntry?.FinishOrder, Items?.HeldItemKey ),
		LocalCurrency
	);
}
