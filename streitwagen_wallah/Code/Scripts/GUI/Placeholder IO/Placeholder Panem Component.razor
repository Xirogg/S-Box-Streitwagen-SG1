@using System;
@using System.Collections.Generic;
@using System.Linq;
@using Sandbox;
@using Sandbox.UI;
@using LapSystem;
@using LapSystem.Rankings;
@inherits PanelComponent
@namespace Sandbox

<root>
	@if ( !IsProxy )
	{
		@* The three lap glyphs get their artwork assigned in code (OnTreeBuilt), not via a
		   url() in the style attribute — see the LapImage properties below for why. *@
		<div class="lap" @ref="LapRow">
			@if ( CurrentLapTexture is not null )
			{
				<div class="lap-img" @ref="CurrentLapImage"></div>
			}
			@if ( LapSlashTexture is not null )
			{
				<div class="lap-img" @ref="SlashImage"></div>
			}
			@if ( MaxLapTexture is not null )
			{
				<div class="lap-img" @ref="MaxLapImage"></div>
			}
		</div>
		<div class="hpbar" style="background-image: url(@HpOutlinePath);">
			<div class="hp-fill-clip" style="width: @(HPPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;">
				<div class="hp-fill" style="background-image: url(@HpFillPath);"></div>
			</div>
		</div>
		<div class="position" style="color: @PositionColor;">@PositionText</div>
		<div class="currency">@LocalCurrency</div>

		<div class="item-slot @(ShowUltimateGlow ? "ultimate" : "")" style="background-image: url(@ItemSlotPath);">
			@if ( ShowItemIcon )
			{
				<div class="item-icon @(ShowUltimateGlow ? "ultimate" : "")" style="background-image: url(@CurrentItemIconPath);"></div>
			}
		</div>

		@if ( ShowPowerMessage )
		{
			<div class="power-message">@PowerMessage</div>
		}

		@if ( ShowCountdown )
		{
			<div class="countdown">@CountdownDisplay</div>
		}

		@if ( ShowFinishMessage )
		{
			<div class="finish-overlay">
				<div class="finish-box">
					<div class="finish-text" style="color: @FinishColour;">@FinishMessage</div>

					<div class="leaderboard">
						@foreach ( var e in FinishedEntries )
						{
							<div class="lb-row">
								<span class="lb-pos" style="color: @LeaderboardColour( e.FinishOrder );">P@(e.FinishOrder)</span>
								<span class="lb-name">@NameFor( e )</span>
							</div>
						}

						@if ( RacingEntries.Count > 0 )
						{
							<div class="lb-section">Noch im Rennen</div>
							@foreach ( var e in RacingEntries )
							{
								<div class="lb-row lb-racing">
									<span class="lb-pos">–</span>
									<span class="lb-name">@NameFor( e )</span>
								</div>
							}
						}
					</div>

					@if ( RacingEntries.Count > 0 )
					{
						<div class="finish-waiting">Warte auf alle Spieler...</div>
					}
				</div>
			</div>
		}
	}
</root>

<style>
	root {
		position: relative;
		left: 132px;
		top: 132px;
		flex-direction: column;
		gap: 118px;
	}
	/* Lap counter, bottom-right. Pulled out of the root flow (was top-left)
	   so the HP bar can take over the top-left corner. Insets mirror the other
	   corner HUD elements: right: 132px like .item-slot, bottom: 132px like
	   .position. Was a "0/3" text label; now three images laid out in a row:
	   current lap / max lap. */
	/* No gap here: it's set from code in OnTreeBuilt so it scales with LapImageHeight
	   instead of staying at a fixed px width as the glyphs grow. */
	.lap {
		position: absolute;
		bottom: 60px;
		right: 60px;
		flex-direction: row;
		align-items: center;
	}
	/* background-image, height and aspect-ratio are all assigned from code in
	   ApplyLapImage — the artwork comes from a Texture object rather than a url(), so it
	   can't live here. background-size: contain is the safety net: if the aspect ever
	   disagrees with the box, the artwork letterboxes instead of stretching. */
	.lap-img {
		background-size: contain;
		background-position: center;
		background-repeat: no-repeat;
	}
	.currency {
		position: absolute;
		bottom: 290px;
		left: 132px;
		color: rgba(255, 220, 80, 1);
		font-size: 96px;
		font-family: Arial;
		text-shadow: 0px 2px 4px black;
	}
	/* Outline acts as the frame + empty-state visual. When the green shrinks
	   below 100% the brown interior of this texture shows through — no red. */
	.hpbar {
		width: 500px;
		height: 80px;
		/* background-image lives inline on the element so it can come from a
		   strongly-typed Texture property the asset pipeline can see. See the
		   HpOutlineTexture field below for the why. */
		background-size: 100% 100%;
		background-repeat: no-repeat;
		position: relative;
	}
	/* Clip box: its width is driven by HPPercent and it hides any green that
	   spills past the right edge. Inset to sit inside the outline's frame. */
	.hp-fill-clip {
		position: absolute;
		top: 18%;
		bottom: 18%;
		left: 0%;
		max-width: 100%;
		overflow: hidden;
		transition: width 0.15s linear;
	}
	/* The green is drawn at the FULL clip width (440px = 500 * 92%) so it
	   doesn't squish as HP drops — it just gets cut off on the right. */
	.hp-fill {
		position: absolute;
		top: 0;
		left: 0;
		width: 500px;
		height: 100%;
		/* background-image set inline from HpFillTexture.ResourcePath; see code block. */
		background-size: 100% 100%;
		background-repeat: no-repeat;
	}
	.position {
		position: absolute;
		bottom: 132px;
		left: 132px;
		color: white;
		font-size: 132px;
		font-family: Arial;
		text-shadow: 0px 2px 4px black;
	}
	/* Item box in the top-right. The ItemSlot texture is the always-visible frame;
	   the .item-icon child (only rendered while an item is held) draws the god-power
	   icon on top of it. Both use inline background-image sourced from strongly-typed
	   Texture properties so the asset pipeline bundles the PNGs for joining clients. */
	.item-slot {
		position: absolute;
		top: 0px;
		right: 60px;
		width: 250px;
		height: 250px;
		background-size: 100% 100%;
		background-repeat: no-repeat;
	}
	.item-icon {
		position: absolute;
		top: -5%;
		left: 0%;
		width: 110%;
		height: 110%;
		background-size: contain;
		background-position: center;
		background-repeat: no-repeat;
	}
	/* Ultimate pickup highlight. isUltimate is rolled at pickup and rides on the held
	   GodPower; the HUD reads it via PlayerItemTracker.HeldPower. The ItemSlot texture
	   is a CIRCLE, so border-radius: 50% rounds the div to match it and the box-shadow
	   traces that circle — a red ring hugging the frame instead of a square-ish haze.
	   The 4th box-shadow value is spread (Sandbox.UI.Shadow.Spread): it expands the
	   shadow outward before the blur, giving a thick, clearly visible ring. Bump spread
	   for a fatter ring, blur for a softer edge. The 0.2s transition fades the glow in
	   on pickup and out on use — same feel as the lobby button's hover glow. */
	.item-slot.ultimate {
		border-radius: 200%;
		box-shadow: 0px 0px 0px 0px rgba(255, 40, 40, 1.00);
		transition: box-shadow 0.2s ease;
	}
	.item-icon.ultimate {
		filter: saturate( 1.15 );
	}
	.countdown {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		color: white;
		font-size: 256px;
		font-family: Arial;
		font-weight: bold;
		text-shadow: 0px 4px 8px black;

	}
	.power-message {
		position: absolute;
		top: 132px;
		left: 50%;
		transform: translateX(-50%);
		padding: 24px 48px;
		background-color: rgba(0, 0, 0, 0.45);
		border-radius: 16px;
		color: white;
		font-size: 64px;
		font-family: Arial;
		font-weight: bold;
		text-shadow: 0px 2px 4px black;
		white-space: nowrap;
	}

	.finish-overlay {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		justify-content: center;
		align-items: center;
	}

	.finish-box {
		padding: 48px 96px;
		background-color: rgba(200, 200, 200, 0.85);
		border-radius: 24px;
		border: 4px solid rgba(255, 255, 255, 0.4);
		flex-direction: column;
		align-items: center;
		gap: 16px;
	}

	.finish-text {
		font-size: 64px;
		font-family: Arial;
		font-weight: bold;
		color: rgba(30, 30, 30, 1);
		text-align: center;
	}

	.finish-waiting {
		font-size: 32px;
		font-family: Arial;
		color: rgba(60, 60, 60, 0.8);
	}

	/* Post-race leaderboard, shown inside the finish box once the local player has
	   finished. Rows come pre-sorted from RaceRankingManager: finishers first
	   (by FinishOrder), then anyone still racing. */
	.leaderboard {
		flex-direction: column;
		align-items: stretch;
		gap: 8px;
		margin-top: 8px;
		min-width: 560px;
	}

	.lb-row {
		flex-direction: row;
		align-items: center;
		gap: 20px;
		font-family: Arial;
		font-size: 40px;
		color: rgba(30, 30, 30, 1);
	}

	.lb-pos {
		font-weight: bold;
		width: 110px;
	}

	.lb-name {
		font-weight: bold;
	}

	/* "Noch im Rennen" separator above the still-racing players. */
	.lb-section {
		margin-top: 16px;
		font-family: Arial;
		font-size: 30px;
		font-weight: bold;
		color: rgba(70, 70, 70, 0.9);
	}

	/* Still-racing rows are dimmed so finishers read as the result. */
	.lb-racing {
		color: rgba(90, 90, 90, 1);
	}

	.lb-racing .lb-pos {
		color: rgba(120, 120, 120, 1);
	}
</style>

@code
{
	// HP-bar artwork. Held as strongly-typed Texture properties (not as hardcoded
	// "/ui/ingame gui/hp bar/..." URL strings in the stylesheet) so the s&box
	// asset-pipeline reference scanner can see them and actually bundle the PNGs
	// into the package joining clients download. A dynamic string built at
	// runtime is invisible to that scanner — the editor host had the files on
	// local disk and looked fine, but joiners would have ended up with blank
	// rectangles the same way the lobby track previews did. Assign these in the
	// inspector on the HUD prefab to the same PNGs the URL literals used to
	// point at (Assets/UI/InGame GUI/HP Bar/HP Outline.png and HP Green.png).
	[Property] public Texture HpOutlineTexture { get; set; }
	[Property] public Texture HpFillTexture { get; set; }

	string HpOutlinePath => HpOutlineTexture?.ResourcePath ?? "";
	string HpFillPath => HpFillTexture?.ResourcePath ?? "";

	// Item-slot artwork. Same strongly-typed-Texture reasoning as the HP bar above:
	// assign these in the inspector on the HUD prefab so the asset pipeline bundles the
	// PNGs for joining clients (a runtime-built URL string is invisible to the scanner).
	//   ItemSlotTexture  -> Assets/UI/InGame GUI/ItemSlot.png  (always-visible frame)
	//   the four *Icon    -> the matching god-power PNG shown inside the slot.
	[Group( "Item Slot" ), Property] public Texture ItemSlotTexture { get; set; }
	[Group( "Item Slot" ), Property] public Texture LavernaIcon { get; set; }
	[Group( "Item Slot" ), Property] public Texture TaranisIcon { get; set; }
	[Group( "Item Slot" ), Property] public Texture MaAtIcon { get; set; }
	[Group( "Item Slot" ), Property] public Texture DionysosIcon { get; set; }

	// Ultimate-variant icons. Shown instead of the normal icon above while the held item
	// was rolled as an Ultimate at pickup (see IsUltimateHeld, driven by
	// PlayerItemTracker.HeldPower.IsUltimate). Drag the matching ULT PNG into each slot in
	// the inspector — same asset-pipeline reasoning as the normal icons. Leaving a god's
	// Ult slot empty is safe: IconForKey falls back to that god's normal icon.
	[Group( "Item Slot (Ultimate)" ), Property] public Texture LavernaUltIcon { get; set; }
	[Group( "Item Slot (Ultimate)" ), Property] public Texture TaranisUltIcon { get; set; }
	[Group( "Item Slot (Ultimate)" ), Property] public Texture MaAtUltIcon { get; set; }
	[Group( "Item Slot (Ultimate)" ), Property] public Texture DionysosUltIcon { get; set; }

	string ItemSlotPath => ItemSlotTexture?.ResourcePath ?? "";

	// Normal-ability icon for a normalized god key. Split out from IconForKey so the
	// Ultimate lookup can fall back to it.
	Texture NormalIconForKey( string norm ) => norm switch
	{
		"laverna" => LavernaIcon,
		"taranis" => TaranisIcon,
		"maat" => MaAtIcon,
		"dionysos" => DionysosIcon,
		_ => null
	};

	// Ultimate-variant icon for a normalized god key. Returns null when that god's Ult
	// slot is left empty, so IconForKey can fall back to the normal icon.
	Texture UltIconForKey( string norm ) => norm switch
	{
		"laverna" => LavernaUltIcon,
		"taranis" => TaranisUltIcon,
		"maat" => MaAtUltIcon,
		"dionysos" => DionysosUltIcon,
		_ => null
	};

	// Held key -> icon. Keys are free-form editor strings ("Dionysos", "Laverna",
	// "Ma'at", "Taranis"), so normalize to letters-only lowercase before matching:
	// "Ma'at" / "ma at" / "MaAt" all collapse to "maat". When the held item is an
	// Ultimate we prefer its Ult icon, but fall back to the normal icon if that slot
	// hasn't been assigned yet — never blank the slot just because an Ult icon is missing.
	Texture IconForKey( string key, bool ultimate )
	{
		if ( string.IsNullOrEmpty( key ) ) return null;
		var norm = new string( key.ToLowerInvariant().Where( char.IsLetter ).ToArray() );
		return ( ultimate ? UltIconForKey( norm ) : null ) ?? NormalIconForKey( norm );
	}

	// Icon for the item the local player currently holds. "" when nothing is held or
	// the key has no assigned icon — the .item-icon div is then not rendered and only
	// the ItemSlot frame shows. Picks the Ultimate variant when the held item is one.
	string CurrentItemIconPath
	{
		get
		{
			var t = Items;
			if ( t is null || !t.HasItem ) return "";
			return IconForKey( t.HeldItemKey, IsUltimateHeld )?.ResourcePath ?? "";
		}
	}

	bool ShowItemIcon => !string.IsNullOrEmpty( CurrentItemIconPath );

	// True while the held item is the Ultimate variant. IsUltimate was rolled at pickup
	// and lives on the owner-local cloned power (HeldPower). On a proxy HUD HeldPower is
	// null (proxies never clone the power), so this is simply false there.
	bool IsUltimateHeld
	{
		get
		{
			var t = Items;
			return t?.HeldPower is not null && t.HeldPower.IsUltimate;
		}
	}

	// Only glow while an icon is actually drawn, so an unmapped key can't leave the slot
	// pulsing over an empty frame.
	bool ShowUltimateGlow => ShowItemIcon && IsUltimateHeld;

	PlayerLapTracker Lap => Components.Get<PlayerLapTracker>( FindMode.EverythingInSelfAndAncestors );
	PlayerDamageSystem Damage => Components.Get<PlayerDamageSystem>( FindMode.EverythingInSelfAndAncestors );

	// The tracker can live on a sibling subtree of the UI panel (e.g. under
	// "Powers"). EverythingInSelfAndAncestors would miss it, so we walk up the
	// chain and search each level's whole subtree — same pattern ItemPrefab uses.
	PlayerItemTracker Items
	{
		get
		{
			var node = GameObject;
			while ( node.IsValid() )
			{
				var t = node.Components.Get<PlayerItemTracker>( FindMode.EverythingInSelfAndDescendants );
				if ( t is not null ) return t;
				node = node.Parent;
			}
			return null;
		}
	}

	// Same ancestor-walk pattern as Items — the notifier lives on the player root
	// (auto-created by GodPower.ResolveNotifier on first activation).
	GodPowerNotifier Notifier
	{
		get
		{
			var node = GameObject;
			while ( node.IsValid() )
			{
				var n = node.Components.Get<GodPowerNotifier>( FindMode.EverythingInSelfAndDescendants );
				if ( n is not null ) return n;
				node = node.Parent;
			}
			return null;
		}
	}

	string PowerMessage => Notifier?.CurrentText ?? "";
	bool ShowPowerMessage => !string.IsNullOrEmpty( PowerMessage );

	// --- Lap counter artwork --------------------------------------------------
	// Replaces the old "0/3" text label. Same strongly-typed-Texture reasoning as the
	// HP bar and item slot above: assign these in the inspector on the HUD prefab so the
	// asset pipeline bundles the PNGs for joining clients.
	//
	// LapNumberTextures is ordered: element 0 is the "lap 1" artwork, element 1 is
	// "lap 2", and so on. Add or swap entries to change how many laps can be drawn —
	// nothing here is hardcoded to three.
	[Group( "Lap Counter" ), Property] public List<Texture> LapNumberTextures { get; set; } = new();
	[Group( "Lap Counter" ), Property] public Texture LapSlashTexture { get; set; }

	// Glyph height in panel px, and the single knob that scales the whole counter — the gap
	// between glyphs is derived from it below. 660 is 5x the 132px font-size the old text
	// label used, which is where the "same size as the label" baseline came from.
	[Group( "Lap Counter" ), Property] public float LapImageHeight { get; set; } = 660f;

	// Gap between glyphs, as a fraction of glyph height. Keeps the spacing proportional at
	// any LapImageHeight (12px at the original 132px height).
	const float LapGapRatio = 12f / 132f;

	// Artwork for a lap number. Index is lap-1, clamped to the list: CurrentLap is 0
	// on the grid until the start line is first crossed, so before the race starts this
	// shows the "lap 1" asset rather than nothing. A MaxLaps higher than the list length
	// falls back to the last entry instead of blanking out.
	Texture LapNumberTexture( int lap )
	{
		var list = LapNumberTextures;
		if ( list is null || list.Count == 0 ) return null;
		return list[Math.Clamp( lap - 1, 0, list.Count - 1 )];
	}

	Texture CurrentLapTexture => Lap is null ? null : LapNumberTexture( Lap.CurrentLap );
	Texture MaxLapTexture => Lap is null ? null : LapNumberTexture( Lap.MaxLaps );

	// Panel handles for the three glyphs, so OnTreeBuilt can push the artwork straight onto
	// them. Null whenever the matching @if didn't render that div.
	Panel LapRow { get; set; }
	Panel CurrentLapImage { get; set; }
	Panel SlashImage { get; set; }
	Panel MaxLapImage { get; set; }

	// The lap art is assigned in the editor as "From Image" (a Sandbox.Resources.ImageFileGenerator
	// that builds the Texture from a PNG), not "From Disk". A generated texture is created at
	// runtime and is NOT a loaded resource, so it has no meaningful ResourcePath — the
	// `background-image: url(...)` trick the HP bar and item slot use would resolve to an empty
	// URL and draw nothing. Style.BackgroundImage takes the Texture object itself, which works
	// for both generated and from-disk textures, so route through it rather than through a path.
	//
	// Height and aspect ratio are set here too rather than in the stylesheet: the aspect comes
	// off the texture's own dimensions, which keeps the row tight around narrow art ("I") and
	// wide art ("III") alike and lets a replacement asset of any proportions lay itself out.
	void ApplyLapImage( Panel panel, Texture tex )
	{
		if ( panel is null || tex is null ) return;

		panel.Style.BackgroundImage = tex;
		panel.Style.Height = Length.Pixels( LapImageHeight );
		panel.Style.AspectRatio = tex.Height > 0 ? (float)tex.Width / tex.Height : 1f;
	}

	// Runs after every tree build, not just the first, so the glyphs re-bind whenever the lap
	// changes and the tree re-renders. The textures are part of BuildHash as well, which covers
	// a generated texture that finishes resolving after the first build.
	protected override void OnTreeBuilt()
	{
		base.OnTreeBuilt();

		if ( LapRow is not null )
			LapRow.Style.ColumnGap = Length.Pixels( LapImageHeight * LapGapRatio );

		ApplyLapImage( CurrentLapImage, CurrentLapTexture );
		ApplyLapImage( SlashImage, LapSlashTexture );
		ApplyLapImage( MaxLapImage, MaxLapTexture );
	}

	// Local player's PG total. Host pushes per-peer mirrors via RpcSetCurrency.
	int LocalCurrency => PublicityCurrencyManager.LocalCurrency;
	float HPPercent => Damage is null ? 0f
		: MathX.Clamp( Damage.CurrentHP / MathF.Max( Damage.MaxHP, 0.0001f ) * 100f, 0f, 100f );

	int CurrentPosition
	{
		get
		{
			var mgr = RaceRankingManager.Instance;
			if ( mgr is null || Lap is null ) return 0;
			foreach ( var entry in mgr.Rankings )
			{
				if ( entry.Tracker == Lap ) return entry.Position;
			}
			return 0;
		}
	}

	string PositionText => CurrentPosition > 0 ? CurrentPosition.ToString() : "-";

	string PositionColor => CurrentPosition switch
	{
		1 => "#2e7d32",
		2 => "#7cb342",
		3 => "#fdd835",
		_ => "#e53935"
	};

	LapSystem.RaceManager Race => LapSystem.RaceManager.Instance;

	bool ShowCountdown => Race is not null && Race.StartCountdownActive;

	string CountdownDisplay
	{
		get
		{
			if ( Race is null ) return "";
			float t = Race.StartCountdownTimeLeft;
			if ( t > 0f ) return MathF.Ceiling( t ).ToString( "0" );
			return "GO!";
		}
	}

	PlayerRankingEntry LocalRankingEntry
	{
		get
		{
			var mgr = RaceRankingManager.Instance;
			if ( mgr is null || Lap is null ) return null;
			foreach ( var entry in mgr.Rankings )
			{
				if ( entry.Tracker == Lap ) return entry;
			}
			return null;
		}
	}

	bool ShowFinishMessage => LocalRankingEntry is not null && LocalRankingEntry.RaceFinished;

	string FinishMessage
	{
		get
		{
			var entry = LocalRankingEntry;
			if ( entry is null ) return "";
			return entry.FinishOrder switch
			{
				1 => "Du hast gewonnen!",
				2 => "Knapp, nächstes mal ist der Sieg deiner!",
				3 => "Die vor dir haben nur gecheated",
				_ => "satz mit x das war wohl nix"
			};
		}
	}

	string FinishColour
	{
		get
		{
			var entry = LocalRankingEntry;
			if (entry is null) return "";
			return entry.FinishOrder switch
			{
				1 => "#2e7d32",
				2 => "#7cb342",
				3 => "#fdd835",
				_ => "#e53935"
			};
		}
	}

	// --- Post-race leaderboard ------------------------------------------------

	// The full ranking is already sorted by RaceRankingManager (finishers first by
	// FinishOrder, then racers by progress), so the UI only needs to split it.
	IReadOnlyList<PlayerRankingEntry> Board =>
		RaceRankingManager.Instance?.Rankings ?? (IReadOnlyList<PlayerRankingEntry>)System.Array.Empty<PlayerRankingEntry>();

	IEnumerable<PlayerRankingEntry> FinishedEntries => Board.Where( e => e.RaceFinished );
	List<PlayerRankingEntry> RacingEntries => Board.Where( e => !e.RaceFinished ).ToList();

	static string NameFor( PlayerRankingEntry e ) =>
		string.IsNullOrEmpty( e?.PlayerName ) ? "Spieler" : e.PlayerName;

	static string LeaderboardColour( int finishOrder ) => finishOrder switch
	{
		1 => "#2e7d32",
		2 => "#7cb342",
		3 => "#fdd835",
		_ => "#e53935"
	};

	// Folds the whole board into one int so BuildHash re-renders the leaderboard
	// when anyone finishes, changes order, or a name resolves.
	int BoardSignature
	{
		get
		{
			var mgr = RaceRankingManager.Instance;
			if ( mgr is null ) return 0;

			var hc = new System.HashCode();
			foreach ( var e in mgr.Rankings )
			{
				hc.Add( e.PlayerId );
				hc.Add( e.RaceFinished );
				hc.Add( e.FinishOrder );
				hc.Add( e.PlayerName );
			}
			return hc.ToHashCode();
		}
	}

	// The lap-counter group is hashed so the tree rebuilds — and OnTreeBuilt re-applies the
	// artwork — when the assigned textures change, when a generated texture finishes
	// resolving, or when LapImageHeight is dragged in the inspector.
	protected override int BuildHash() => System.HashCode.Combine(
		System.HashCode.Combine( IsProxy, Lap?.CurrentLap, Damage?.CurrentHP, CurrentPosition, Race?.StartCountdownTimeLeft, LocalRankingEntry?.RaceFinished, LocalRankingEntry?.FinishOrder, Items?.HeldItemKey ),
		System.HashCode.Combine( LocalCurrency, PowerMessage, BoardSignature, ShowUltimateGlow ),
		System.HashCode.Combine( Lap?.MaxLaps, CurrentLapTexture, LapSlashTexture, MaxLapTexture, LapImageHeight )
	);
}
